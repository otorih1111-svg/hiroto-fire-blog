# 全ページにインデックス許可（Cloudflare Pagesのnoindex自動付与を上書き）
/*
  X-Robots-Tag: index, follow

# サイトマップ自体は検索結果に出さない（SEO標準の作法）
/sitemap-index.xml
  X-Robots-Tag: noindex, follow

/sitemap-0.xml
  X-Robots-Tag: noindex, follow

# サムネイル画像：更新のたびに最新版を返す
/thumbnails/*
  Cache-Control: public, max-age=0, must-revalidate

# OGP画像：同様
/og/*
  Cache-Control: public, max-age=0, must-revalidate
