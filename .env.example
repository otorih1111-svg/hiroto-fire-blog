# ============================================================
# ひろとの副業実録ブログ — 環境変数テンプレート
# このファイルをコピーして .env を作成してください。
# .env は絶対に Git にコミットしないこと。
# ============================================================

# ---- Claude API（記事自動生成に使用） ----
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# ---- Google Analytics 測定ID ----
# 未設定の場合は G-LRT5BKLD8Y が使われます
PUBLIC_GA_ID=G-LRT5BKLD8Y

# ---- LINE公式アカウントURL ----
# 未設定の場合は既存のURLが使われます
PUBLIC_LINE_URL=https://line.me/R/ti/p/%40103khwdx
