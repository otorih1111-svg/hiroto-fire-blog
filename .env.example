# ============================================================
# ひろとの副業実録ブログ — 環境変数テンプレート
# このファイルをコピーして .env を作成してください。
# .env は絶対に Git にコミットしないこと。
# ============================================================

# ---- Claude API（記事自動生成に使用） ----
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# ---- Google Analytics 測定ID ----
# 未設定の場合は G-LRT5BKLD8Y が使われます
PUBLIC_GA_ID=G-LRT5BKLD8Y

# ---- Search Console / GA4 読み取り用 ----
# Codex からレポートを見るとき、および sitemap 自動再送信に使用します
# GOOGLE_SERVICE_ACCOUNT_FILE は相対パスでも可（例: google-credentials.json）
GOOGLE_SERVICE_ACCOUNT_FILE=google-credentials.json
GSC_SITE_URL=sc-domain:hiroto-fire.com
GA4_PROPERTY_ID=

# ---- LINE公式アカウントURL（現在未使用・メルマガに置き換え済み） ----
PUBLIC_LINE_URL=https://line.me/R/ti/p/%40103khwdx

# ---- メルマガ（オレンジメール）読者登録フォームURL ----
# 未設定の場合は既存のURLが使われます
PUBLIC_MAIL_URL=https://mail.os7.biz/add/0B3Y

# ---- IndexNow 通知用キー ----
# 32文字前後の英数字を設定してください
INDEXNOW_KEY=

# ---- Google Ads API（KW提案の自動生成に使用） ----
# 取得方法:
#   1. Google Cloud Console でプロジェクト作成 → OAuthクライアントID（デスクトップアプリ）を作成
#      → GOOGLE_ADS_CLIENT_ID / GOOGLE_ADS_CLIENT_SECRET を設定
#   2. Google Ads API Center (https://ads.google.com/aw/apicenter) で
#      開発者トークンを取得 → GOOGLE_ADS_DEVELOPER_TOKEN に設定
#   3. python3 scripts/get_google_ads_refresh_token.py を実行
#      → GOOGLE_ADS_REFRESH_TOKEN が自動保存される
#   4. キーワードプランナーを使うGoogle Ads アカウントの顧客ID（xxx-xxx-xxxx）を
#      GOOGLE_ADS_CUSTOMER_ID に設定（MCC配下の場合はGOOGLE_ADS_LOGIN_CUSTOMER_IDにMCCのIDも設定）
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
