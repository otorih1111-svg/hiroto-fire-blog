{
  "name": "hiroto-fire-blog",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "prebuild": "node scripts/prepare_indexnow_key.mjs && node scripts/generate_redirects.mjs",
    "dev": "astro dev",
    "build": "astro build",
    "build:seo": "npm run build && npm run seo:notify",
    "preview": "astro preview",
    "astro": "astro",
    "seo:notify": "node scripts/post_deploy_indexing.mjs",
    "seo:notify:live": "node scripts/post_deploy_indexing.mjs --wait-live",
    "seo:notify:all": "node scripts/post_deploy_indexing.mjs --all",
    "seo:google": "python3 scripts/submit_google_publish_signals.py",
    "seo:google:dry": "python3 scripts/submit_google_publish_signals.py --dry-run",
    "seo:publish": "npm run seo:notify && npm run seo:google"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.2",
    "astro": "^6.3.1"
  }
}
