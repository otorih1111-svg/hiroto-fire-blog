              <a href="https://note.com/hiroto00" target="_blank" rel="noopener noreferrer" class="footer-sns-link" aria-label="note">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M8.844 4.506c-.147 0-.294.07-.368.198L3.07 13.26c-.147.255-.074.581.148.766l5.7 4.656c.22.181.515.198.735.043l9.315-6.646c.441-.313.441-.978 0-1.29L9.653 4.677c-.22-.156-.515-.17-.809-.17zm.184 1.87l8.137 5.806-8.137 5.807V6.376zm-1.107.128v11.488l-4.37-3.567 4.37-7.921z"/></svg>
