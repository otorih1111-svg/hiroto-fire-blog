          <div class="footer-nav">
            <h3>カテゴリ</h3>
            <ul>
              {categoryDefs.map(cat => (
                <li><a href={`/category/${encodeURIComponent(cat.name)}/`}>{cat.emoji} {cat.name}</a></li>
              ))}
            </ul>
          </div>
          <div class="footer-nav">
            <h3>リンク</h3>
            <ul>
              <li><a href="/blog/about-hiroto/">プロフィール</a></li>
              <li><a href="/recommended-books/">おすすめ書籍</a></li>
