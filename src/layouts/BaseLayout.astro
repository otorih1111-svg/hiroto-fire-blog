---
import '../styles/global.css';
import LineBanner from '../components/LineBanner.astro';
import LineBannerSide from '../components/LineBannerSide.astro';
import { getCollection } from 'astro:content';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  article?: boolean;
  pubDate?: Date;
  category?: string;
}

const {
  title,
  description = '40代シングルファーザーのひろとが、家計改善と資産づくりを通じてFIREを目指すブログ。固定費見直し、新NISA、楽天経済圏の体験談を正直に発信しています。',
  ogImage,
  article = false,
  pubDate,
  category,
} = Astro.props;

const siteTitle = 'ひろとの家計改善とFIREブログ';
const siteUrl   = 'https://hiroto-fire.com';

const GA_ID    = import.meta.env.PUBLIC_GA_ID    || 'G-LRT5BKLD8Y';
const LINE_URL = import.meta.env.PUBLIC_LINE_URL || 'https://line.me/R/ti/p/%40103khwdx';

const fullTitle   = title === siteTitle ? title : `${title} | ${siteTitle}`;
// OGP画像: ogImageが指定されていればそれを使い、なければデフォルト
// 動的OGP生成は廃止（@resvg/resvg-js の Cloudflare Linux 非互換のため）
const ogImageUrl  = ogImage
  ? `${siteUrl}${ogImage}`
  : `${siteUrl}/og/default.png`;

// カテゴリ別記事数を集計
const allPosts = await getCollection('blog', ({ data }) => !data.draft);

const categoryDefs = [
  { name: '節約・家計', emoji: '💰' },
  { name: '投資・FIRE', emoji: '📈' },
  { name: '副業・AI',   emoji: '🤖' },
];

const categoryCounts = categoryDefs.map(cat => ({
  ...cat,
  count: allPosts.filter(p => p.data.category === cat.name).length,
}));

const popularPosts = [
  { title: '副業3ヶ月、収益ゼロでも続ける理由【40代シングル父のリアル】', slug: 'hajimete-no-fukugyo' },
  { title: '固定費を見直したら月1万円以上浮いた話', slug: 'koteihi-minaoshi' },
  { title: '新NISAは月1万円でも意味ある？40代シングルファーザーが考えたこと', slug: 'nisa-tsumitate-40dai' },
];
---

<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />

  <!-- OGP -->
  <meta property="og:type"        content={article ? 'article' : 'website'} />
  <meta property="og:title"       content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image"       content={ogImageUrl} />
  <meta property="og:url"         content={Astro.url.href} />
  <meta property="og:site_name"   content={siteTitle} />
  <meta property="og:locale"      content="ja_JP" />
  {article && pubDate && <meta property="article:published_time" content={pubDate.toISOString()} />}

  <!-- Twitter Card -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={ogImageUrl} />

  <link rel="canonical" href={Astro.url.href} />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

  <!-- Google AdSense -->
  <script
    async
    src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-7447753970990515"
    crossorigin="anonymous"
  ></script>

  <!-- Google Analytics -->
  <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}></script>
  <script define:vars={{ GA_ID }}>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', GA_ID);
  </script>

  <title>{fullTitle}</title>
</head>
<body>
  <div class="page-wrapper">

    <!-- ヘッダー -->
    <header class="site-header">
      <div class="container">
        <a href="/" class="site-logo">
          <span class="site-logo-icon">🌱</span>
          <span class="site-logo-title">ひろとの家計改善とFIREブログ</span>
        </a>
        <nav>
          <ul class="site-nav">
            <li><a href="/">トップ</a></li>
            <li><a href="/blog/about-hiroto/">プロフィール</a></li>
          </ul>
        </nav>
      </div>
    </header>

    <!-- メインコンテンツ + サイドバー -->
    <main>
      <div class="layout-outer">
        <div class="main-col">
          <slot />
        </div>

        <!-- サイドバー -->
        <aside class="sidebar-col">

          <!-- LINE CTAウィジェット（最上部・最重要） -->
          <LineBannerSide />

          <!-- プロフィールカード -->
          <div class="sidebar-profile-card">
            <div class="sidebar-section-title">運営者情報</div>
            <div class="sidebar-profile-avatar"><img src="/images/hiroto-avatar.png" alt="ひろと" /></div>
            <p class="sidebar-profile-name">ひろと</p>
            <p class="sidebar-profile-bio">
              40代・千葉在住のシングルファーザー。10歳の息子のために、家計改善と資産づくりを通じてFIREを目指す過程をThreads・X・noteで発信中。
            </p>
            <div class="sidebar-sns">
              <a href="https://x.com/hiroto00ih" target="_blank" rel="noopener noreferrer" class="sidebar-sns-link">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.258 5.63 5.906-5.63Zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                X
