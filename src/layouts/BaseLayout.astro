---
import '../styles/global.css';
import LineBanner from '../components/LineBanner.astro';
import LineBannerSide from '../components/LineBannerSide.astro';
import { getCollection } from 'astro:content';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  article?: boolean;
  pubDate?: Date;
  category?: string;
}

const {
  title,
  description = 'シングル父がAIと副業でFIREを目指す過程をリアルに発信するブログ',
  ogImage,
  article = false,
  pubDate,
  category,
} = Astro.props;

const siteTitle = 'ひろとの副業実録';
const siteUrl   = 'https://hiroto-fire.com';

const GA_ID    = import.meta.env.PUBLIC_GA_ID    || 'G-LRT5BKLD8Y';
const LINE_URL = import.meta.env.PUBLIC_LINE_URL || 'https://line.me/R/ti/p/%40103khwdx';

const fullTitle   = title === siteTitle ? title : `${title} | ${siteTitle}`;
const ogImageUrl  = ogImage ? `${siteUrl}${ogImage}` : `${siteUrl}/images/og-default.png`;

// カテゴリ別記事数を集計
const allPosts = await getCollection('blog', ({ data }) => !data.draft);

const categoryDefs = [
  { name: '副業実録',       emoji: '📝' },
  { name: 'AI活用',         emoji: '🤖' },
  { name: 'FIRE設計',       emoji: '🔥' },
  { name: 'シングル父の日常', emoji: '👨‍👦' },
  { name: '買ってよかった',  emoji: '🛒' },
];

const categoryCounts = categoryDefs.map(cat => ({
  ...cat,
  count: allPosts.filter(p => p.data.category === cat.name).length,
}));

const popularPosts = [
  { title: '副業ゼロから始めた最初の一歩', slug: 'hajimete-no-fukugyo' },
  { title: 'シングル父がFIREを目指す理由を正直に書く', slug: '2026-05-14-single-fatherfire' },
  { title: '40代がAI副業を始めた理由', slug: 'ai-fukugyo-hajimekata' },
];
---

<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />

  <!-- OGP -->
  <meta property="og:type"        content={article ? 'article' : 'website'} />
  <meta property="og:title"       content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image"       content={ogImageUrl} />
  <meta property="og:url"         content={Astro.url.href} />
  <meta property="og:site_name"   content={siteTitle} />
  <meta property="og:locale"      content="ja_JP" />
  {article && pubDate && <meta property="article:published_time" content={pubDate.toISOString()} />}

  <!-- Twitter Card -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={ogImageUrl} />

  <link rel="canonical" href={Astro.url.href} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Google Analytics -->
  <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}></script>
  <script define:vars={{ GA_ID }}>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', GA_ID);
  </script>

  <title>{fullTitle}</title>
</head>
<body>
  <div class="page-wrapper">

    <!-- ヘッダー -->
    <header class="site-header">
      <div class="container">
        <a href="/" class="site-logo">
          <span class="site-logo-icon">🌱</span>
          <h1>ひろとの副業実録</h1>
        </a>
        <nav>
          <ul class="site-nav">
            <li><a href="/">トップ</a></li>
            <li><a href="/about/">プロフィール</a></li>
            <li>
              <a href={LINE_URL} target="_blank" rel="noopener noreferrer" class="nav-line-btn">
                📩 LINE登録（無料）
              </a>
            </li>
          </ul>
        </nav>
      </div>
    </header>

    <!-- メインコンテンツ + サイドバー -->
    <main>
      <div class="layout-outer">
        <div class="main-col">
          <slot />
        </div>

        <!-- サイドバー -->
        <aside class="sidebar-col">

          <!-- LINE CTAウィジェット（最上部・最重要） -->
          <LineBannerSide />

          <!-- プロフィールカード -->
          <div class="sidebar-profile-card">
            <div class="sidebar-section-title">運営者情報</div>
            <div class="sidebar-profile-avatar">👨‍👦</div>
            <p class="sidebar-profile-name">ひろと</p>
            <p class="sidebar-profile-bio">
              40代・千葉在住のシングル父。10歳の息子のためにAI副業でFIREを目指す実録を発信中。失敗も成果なしも正直に書きます。
            </p>
            <a href="/about/" class="sidebar-profile-link">プロフィール詳細 →</a>
          </div>

          <!-- カテゴリ一覧 -->
          <div class="sidebar-category-card">
            <div class="sidebar-section-title">カテゴリ</div>
            <ul class="sidebar-category-list">
              {categoryCounts.map(cat => (
                <li>
                  <a href={`/category/${cat.name}/`}>
                    <span>{cat.emoji} {cat.name}</span>
                    <span class="sidebar-category-count">{cat.count}</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>

          <!-- 人気記事 -->
          <div class="sidebar-popular-card">
            <div class="sidebar-section-title">人気記事</div>
            <ul class="sidebar-popular-list">
              {popularPosts.map((post, i) => (
                <li class="sidebar-popular-item">
                  <a href={`/blog/${post.slug}/`}>
                    <span class="sidebar-popular-num">{i + 1}</span>
                    <span>{post.title}</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>

        </aside>
      </div>
    </main>

    <!-- LINEバナー（フッター上） -->
    <LineBanner />

    <!-- フッター -->
    <footer class="site-footer">
      <div class="container">
        <div class="footer-inner">
          <div class="footer-brand">
            <h2>ひろとの副業実録</h2>
            <p>40代シングル父がAIと副業でFIREを目指す過程をリアルに発信するブログ。失敗も成功も正直に書きます。</p>
          </div>
          <div class="footer-nav">
            <h3>カテゴリ</h3>
            <ul>
              {categoryDefs.map(cat => (
                <li><a href={`/category/${cat.name}/`}>{cat.name}</a></li>
              ))}
              <li><a href="/about/">プロフィール</a></li>
            </ul>
          </div>
        </div>
        <div class="footer-bottom">
          <p>当サイトはアフィリエイトプログラムに参加しています。記事内リンクから商品・サービス利用時に報酬が発生する場合があります。</p>
          <p style="margin-top: 6px;">&copy; 2026 ひろとの副業実録</p>
        </div>
      </div>
    </footer>

  </div>
</body>
</html>
