                Threads
              </a>
              <a href="https://note.com/hiroto00" target="_blank" rel="noopener noreferrer" class="sidebar-sns-link">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M8.844 4.506c-.147 0-.294.07-.368.198L3.07 13.26c-.147.255-.074.581.148.766l5.7 4.656c.22.181.515.198.735.043l9.315-6.646c.441-.313.441-.978 0-1.29L9.653 4.677c-.22-.156-.515-.17-.809-.17zm.184 1.87l8.137 5.806-8.137 5.807V6.376zm-1.107.128v11.488l-4.37-3.567 4.37-7.921z"/></svg>
                note
              </a>
            </div>
            <a href="/blog/about-hiroto/" class="sidebar-profile-link">プロフィール詳細 →</a>
          </div>

          <!-- カテゴリ一覧 -->
          <div class="sidebar-category-card">
            <div class="sidebar-section-title">カテゴリ</div>
            <ul class="sidebar-category-list">
              {categoryCounts.map(cat => (
                <li class="sidebar-category-item">
                  <a href={`/category/${cat.name}/`}>
                    <span>{cat.emoji} {cat.name}</span>
                    <span class="sidebar-category-count">{cat.count}</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>

          <!-- テーマ別に読む -->
          <div class="sidebar-category-card">
            <div class="sidebar-section-title">テーマ別に読む</div>
            <ul class="sidebar-category-list">
              <li class="sidebar-category-item">
                <a href="/recommended-books/">
                  <span>📚 おすすめ書籍</span>
                </a>
              </li>
              <li class="sidebar-category-item">
                <a href="/katteyokatta/">
                  <span>👍 買ってよかったモノ</span>
                </a>
              </li>
            </ul>
          </div>

          <!-- 人気記事 -->
          <div class="sidebar-popular-card">
            <div class="sidebar-section-title">人気記事</div>
            <ul class="sidebar-popular-list">
              {popularPosts.map((post, i) => (
                <li class="sidebar-popular-item">
                  <a href={`/blog/${post.slug}/`}>
                    <span class="sidebar-popular-num">{i + 1}</span>
                    <span>{post.title}</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>

        </aside>
      </div>
    </main>

    <LineBanner />

    <!-- フッター -->
    <footer class="site-footer">
      <div class="container">
        <div class="footer-inner">
          <div class="footer-brand">
            <h2>ひろとの家計改善とFIREブログ</h2>
            <p>40代シングルファーザーのひろとが、家計改善と資産づくりを通じてFIREを目指すブログ。固定費見直し、新NISA、楽天経済圏の体験談を正直に発信しています。</p>
            <div class="footer-sns">
              <a href="https://x.com/hiroto00ih" target="_blank" rel="noopener noreferrer" class="footer-sns-link" aria-label="X（Twitter）">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.258 5.63 5.906-5.63Zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                X
              </a>
              <a href="https://www.threads.net/@hiroto00ih" target="_blank" rel="noopener noreferrer" class="footer-sns-link" aria-label="Threads">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12.186 24h-.007c-3.581-.024-6.334-1.205-8.184-3.509C2.35 18.44 1.5 15.586 1.472 12.01v-.017c.028-3.579.879-6.43 2.525-8.482C5.845 1.205 8.6.024 12.18 0h.014c2.746.02 5.043.725 6.826 2.098 1.677 1.29 2.858 3.13 3.509 5.467l-2.04.569c-1.054-3.78-3.553-5.622-7.295-5.637-2.914.02-5.086.818-6.458 2.371C5.416 6.443 4.73 8.784 4.705 12c.025 3.213.711 5.568 2.025 7.137 1.374 1.558 3.543 2.356 6.462 2.373 2.616-.015 4.333-.714 5.274-2.139.503-.754.818-1.779.937-3.048H15.84c-.092 1.48-.625 2.59-1.587 3.3-.875.647-1.997.97-3.334.97h-.153c-1.473-.028-2.694-.439-3.635-1.223-.886-.737-1.442-1.818-1.66-3.224a14.09 14.09 0 0 1-.065-1.516 13.1 13.1 0 0 1 .065-1.514c.218-1.399.774-2.475 1.66-3.21.94-.782 2.163-1.19 3.636-1.217h.07c1.477.026 2.7.44 3.635 1.23.917.773 1.474 1.867 1.658 3.26.078.597.117 1.234.117 1.895 0 3.047-.67 5.329-1.99 6.784-.993 1.095-2.4 1.707-4.18 1.826h-.152c-.655 0-1.287-.065-1.888-.194a7.4 7.4 0 0 1-1.68-.564l.814-1.857c.399.175.826.305 1.278.388.403.076.825.114 1.253.115h.082c1.239-.085 2.187-.51 2.821-1.263.857-1.016 1.293-2.724 1.293-5.048 0-.558-.033-1.086-.097-1.57-.118-.953-.437-1.694-.953-2.207-.524-.52-1.233-.799-2.108-.83h-.048c-.875.03-1.585.314-2.108.842-.524.524-.84 1.279-.94 2.24a11.14 11.14 0 0 0-.053 1.125c0 .392.018.763.053 1.106.1.966.416 1.724.94 2.248.526.527 1.238.809 2.114.838h.04c.79-.026 1.427-.26 1.895-.695.428-.401.683-.97.761-1.697h2.059c-.135 1.468-.657 2.635-1.558 3.474-1.01.94-2.362 1.42-4.018 1.43h-.072Z"/></svg>
                Threads
