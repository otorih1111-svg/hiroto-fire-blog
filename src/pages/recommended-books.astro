function makeRakutenLink(productId: number) {
  return (
    AFFILIATE_URL_PREFIX +
    encodeURIComponent('https://item.rakuten.co.jp/book/' + productId + '/') +
    AFFILIATE_URL_SUFFIX
  );
}

