---
import BaseLayout from '../layouts/BaseLayout.astro';

function makeCover(title: string, accent: string, subline: string) {
  const svg = `
    <svg xmlns="http://www.w3.org/2000/svg" width="300" height="420" viewBox="0 0 300 420">
      <rect width="300" height="420" rx="18" fill="${accent}" />
      <rect x="18" y="18" width="264" height="384" rx="12" fill="rgba(255,255,255,0.12)" />
      <text x="32" y="74" fill="#ffffff" font-size="20" font-family="Arial, sans-serif" font-weight="700">${subline}</text>
      <foreignObject x="28" y="110" width="244" height="240">
        <div xmlns="http://www.w3.org/1999/xhtml" style="color:#fff;font-size:30px;line-height:1.45;font-family:Arial,sans-serif;font-weight:700;">
          ${title}
        </div>
      </foreignObject>
    </svg>
  `;
  return `data:image/svg+xml;charset=utf-8,${encodeURIComponent(svg)}`;
}

const sections = [
  {
    title: 'お金・FIRE入門',
    note: 'まず土台を整えたいときに、考え方から入りやすかった本です。',
    books: [
      {
        title: 'お金の大学',
        author: '両学長',
        body: 'お金の基礎を学ぶならまずこの1冊。貯める・稼ぐ・増やす・守る・使うの5つの力を、生活に落とし込みやすい形で解説しています。',
        cover: makeCover('お金の大学', '#2f855a', 'お金・FIRE入門'),
        rakuten:
          'https://hb.afl.rakuten.co.jp/ichiba/52e5bfa5.fe4aaada.52e5bfa6.88ed0deb/?pc=https%3A%2F%2Fitem.rakuten.co.jp%2Fbook%2F18041936%2F&link_type=picttext&ut=eyJwYWdlIjoiaXRlbSIsInR5cGUiOiJwaWN0dGV4dCIsInNpemUiOiIyNDB4MjQwIiwibmFtIjoxLCJuYW1wIjoicmlnaHQiLCJjb20iOjEsImNvbXAiOiJkb3duIiwicHJpY2UiOjEsImJvciI6MSwiY29sIjoxLCJiYnRuIjoxLCJwcm9kIjowLCJhbXAiOmZhbHNlfQ%3D%3D',
      },
    ],
  },
  {
    title: '投資入門',
    note: '焦って売買する前に、長期投資の考え方を落ち着いて学べた本を置いています。',
    books: [
      {
        title: 'ウォール街のランダム・ウォーカー',
        author: '',
        body: 'インデックス投資の定番書。長期投資の考え方を身につけたいときに、一度は読んでおきたい内容です。',
        cover: makeCover('ウォール街のランダム・ウォーカー', '#2b6cb0', '投資入門'),
        rakuten:
          'https://hb.afl.rakuten.co.jp/ichiba/52e5bfa5.fe4aaada.52e5bfa6.88ed0deb/?pc=https%3A%2F%2Fitem.rakuten.co.jp%2Fbook%2F17455659%2F&link_type=picttext&ut=eyJwYWdlIjoiaXRlbSIsInR5cGUiOiJwaWN0dGV4dCIsInNpemUiOiIyNDB4MjQwIiwibmFtIjoxLCJuYW1wIjoicmlnaHQiLCJjb20iOjEsImNvbXAiOiJkb3duIiwicHJpY2UiOjEsImJvciI6MSwiY29sIjoxLCJiYnRuIjoxLCJwcm9kIjowLCJhbXAiOmZhbHNlfQ%3D%3D',
      },
      {
        title: '敗者のゲーム',
        author: '',
        body: 'プロに勝てない理由と、インデックス投資の合理性を落ち着いて説明してくれる本です。',
        cover: makeCover('敗者のゲーム', '#1e40af', '投資入門'),
        rakuten:
          'https://hb.afl.rakuten.co.jp/ichiba/52e5bfa5.fe4aaada.52e5bfa6.88ed0deb/?pc=https%3A%2F%2Fitem.rakuten.co.jp%2Fbook%2F16973485%2F&link_type=picttext&ut=eyJwYWdlIjoiaXRlbSIsInR5cGUiOiJwaWN0dGV4dCIsInNpemUiOiIyNDB4MjQwIiwibmFtIjoxLCJuYW1wIjoicmlnaHQiLCJjb20iOjEsImNvbXAiOiJkb3duIiwicHJpY2UiOjEsImJvciI6MSwiY29sIjoxLCJiYnRuIjoxLCJwcm9kIjowLCJhbXAiOmZhbHNlfQ%3D%3D',
      },
    ],
  },
  {
    title: '副業・ブログ',
    note: '副業ブログを現実的に進めるうえで、手順を具体化しやすかった本です。',
    books: [
      {
        title: 'ブログで5億円稼いだ方法',
        author: 'クニトミ',
        body: '副業ブログの実践書。抽象論よりも、何をどう進めるかの手順が具体的に書かれています。',
        cover: makeCover('ブログで5億円稼いだ方法', '#dd6b20', '副業・ブログ'),
        rakuten:
          'https://hb.afl.rakuten.co.jp/ichiba/52e5bfa5.fe4aaada.52e5bfa6.88ed0deb/?pc=https%3A%2F%2Fitem.rakuten.co.jp%2Fbook%2F17148399%2F&link_type=picttext&ut=eyJwYWdlIjoiaXRlbSIsInR5cGUiOiJwaWN0dGV4dCIsInNpemUiOiIyNDB4MjQwIiwibmFtIjoxLCJuYW1wIjoicmlnaHQiLCJjb20iOjEsImNvbXAiOiJkb3duIiwicHJpY2UiOjEsImJvciI6MSwiY29sIjoxLCJiYnRuIjoxLCJwcm9kIjowLCJhbXAiOmZhbHNlfQ%3D%3D',
      },
    ],
  },
  {
    title: 'マインドセット',
    note: 'お金に対する見方を変えるきっかけになった本です。',
