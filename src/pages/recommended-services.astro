---
import BaseLayout from '../layouts/BaseLayout.astro';

const sections = [
  {
    title: '副業・アフィリエイト',
    note: '最初の1万円を作る入口として、実際に触ってみて動きやすかったものを優先しています。',
    services: [
      {
        name: 'ハピタス',
        body: '自己アフィリで最初の1万円を稼ぐならここから。スマホだけで始めやすく、普段の買い物でもポイントが貯まります。',
        href: 'https://hapitas.jp/appinvite?i=25519472&route=pcText',
        label: 'ハピタスに登録する',
        meta: '招待コード：QSEKKE',
        sponsored: true,
      },
      {
        name: 'A8.net',
        body: '国内最大手ASP。案件数が多く、自己アフィリやブログ用の広告を探しやすいので、初心者でも登録しやすいです。',
        href: 'https://px.a8.net/svt/ejp?a8mat=35AXS6+691W7U+0K+10FXXU',
        label: 'A8.netを見てみる',
        sponsored: true,
      },
    ],
  },
  {
    title: 'お金の相談',
    note: '副業で増やす前に、家計や保険の土台を見直したいときに候補になるサービスです。',
    services: [
      {
        name: 'FP無料相談',
        body: '家計・保険・資産形成の悩みを無料で相談できます。離婚後の家計整理や、FIREに向けた土台確認にも向いています。',
        href: 'https://px.a8.net/svt/ejp?a8mat=4B3MEP+DK7HLM+5MAS+5YJRM',
        label: 'FP無料相談を見てみる',
        sponsored: true,
      },
    ],
  },
  {
    title: '節約・生活費削減（今後追加予定）',
    note: '生活費を整えることは、副業資金を作ることと同じだと感じています。ここは今後、比較記事と一緒に増やします。',
    services: [
      {
        name: '格安SIM',
        body: '準備中',
        planned: true,
      },
      {
        name: 'ネット回線',
        body: '準備中',
        planned: true,
      },
      {
        name: 'ふるさと納税',
        body: '準備中',
        planned: true,
      },
    ],
  },
  {
    title: '副業スキル（今後追加予定）',
    note: '副業を継続するためのスキル投資も、実際に比較したものから順番に整理していきます。',
    services: [
      {
        name: 'プログラミングスクール',
        body: '準備中',
        planned: true,
      },
    ],
  },
];
---

<BaseLayout
  title="ひろとのおすすめサービス一覧【副業×節約×FIRE】"
  description="シングル父ひろとが実際に使ってよかったサービスをまとめています。"
>
  <div class="resource-page">
    <nav class="breadcrumb">
      <a href="/">トップ</a>
      <span>›</span>
      <span>おすすめサービス</span>
    </nav>

    <header class="resource-hero">
      <p class="resource-eyebrow">Recommended Services</p>
      <h1>ひろとのおすすめサービス一覧【副業×節約×FIRE】</h1>
      <p>
        シングル父として生活費と副業を両立しながら動く中で、「これは入口として使いやすい」と感じたサービスをまとめました。
        派手に稼げる話ではなく、最初の一歩を踏み出しやすいかどうかで整理しています。
      </p>
    </header>

    <div class="resource-notice">
      <strong>PRについて</strong>
      <span>このページにはアフィリエイト広告を含みます。実際に使うかどうかは、必ずご自身で条件を確認して判断してください。</span>
    </div>

    <div class="resource-sections">
      {sections.map((section, index) => (
        <section class="resource-section">
          <div class="resource-section-head">
            <span class="resource-index">{String(index + 1).padStart(2, '0')}</span>
            <div>
              <h2>{section.title}</h2>
              <p>{section.note}</p>
            </div>
          </div>
          <div class="resource-list">
            {section.services.map((service) => (
              <article class:list={['resource-card', service.planned && 'is-planned']}>
                <div class="resource-card-top">
                  <h3>{service.name}</h3>
                  {service.sponsored && <span class="pr-badge">PR</span>}
                  {service.planned && <span class="planned-badge">準備中</span>}
                </div>
                <p>{service.body}</p>
                {service.meta && <p class="resource-meta">{service.meta}</p>}
                {service.href ? (
                  <a
                    href={service.href}
                    class="resource-link"
                    target="_blank"
                    rel={service.sponsored ? 'nofollow sponsored noopener noreferrer' : 'noopener noreferrer'}
                  >
                    {service.label}
                  </a>
                ) : (
                  <span class="resource-link is-disabled">比較記事の準備中</span>
                )}
              </article>
            ))}
          </div>
        </section>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
.resource-page {
  max-width: 920px;
  margin: 0 auto;
}

.resource-hero {
  padding: 34px 0 28px;
  border-bottom: 1px solid var(--color-border);
}

.resource-eyebrow {
  display: inline-block;
  margin-bottom: 10px;
  padding: 4px 10px;
  background: var(--color-accent-light);
  color: var(--color-accent);
  font-size: 0.78rem;
  font-weight: 700;
}

.resource-hero h1 {
  margin: 0 0 16px;
  font-size: 2rem;
  line-height: 1.45;
  letter-spacing: 0;
}

.resource-hero p {
  max-width: 760px;
  color: var(--color-text-muted);
  line-height: 1.9;
}

.resource-notice {
  display: flex;
  gap: 12px;
  align-items: flex-start;
  margin: 24px 0;
  padding: 16px 18px;
  border-left: 4px solid var(--color-accent);
  background: #f7fbf3;
  line-height: 1.8;
}

.resource-notice strong {
  flex: 0 0 auto;
  color: var(--color-accent);
}

.resource-sections {
  display: grid;
  gap: 34px;
}

.resource-section {
  padding: 26px 0 30px;
  border-bottom: 1px solid var(--color-border);
}

.resource-section-head {
  display: grid;
  grid-template-columns: 54px 1fr;
  gap: 18px;
  align-items: start;
  margin-bottom: 18px;
}

.resource-index {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 48px;
  height: 48px;
  border: 1px solid var(--color-accent);
  color: var(--color-accent);
  font-weight: 700;
}

.resource-section h2 {
  margin: 0 0 8px;
  font-size: 1.35rem;
  letter-spacing: 0;
}

.resource-section-head p {
  color: var(--color-text-muted);
  line-height: 1.8;
}

.resource-list {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12px;
}

.resource-card {
  border: 1px solid var(--color-border);
  border-radius: 8px;
  padding: 18px;
  background: #fff;
}

.resource-card.is-planned {
  background: #f8f8f8;
}

.resource-card-top {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 8px;
  margin-bottom: 10px;
}

.resource-card h3 {
  margin: 0;
  color: var(--color-text);
  font-size: 1rem;
  letter-spacing: 0;
}

.resource-card p {
  color: var(--color-text-muted);
  font-size: 0.92rem;
  line-height: 1.8;
}

.resource-meta {
  margin-top: 10px;
  font-size: 0.84rem;
  color: var(--color-accent);
  font-weight: 700;
}

.pr-badge,
.planned-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 42px;
  height: 24px;
  padding: 0 10px;
  border-radius: 999px;
  font-size: 0.72rem;
  font-weight: 700;
}

.pr-badge {
  background: var(--color-accent-light);
  color: var(--color-accent);
}

.planned-badge {
  background: #ececec;
  color: #7b7b7b;
}

.resource-link {
  display: inline-block;
  margin-top: 12px;
  color: var(--color-accent);
  font-weight: 700;
}

.resource-link.is-disabled {
  color: #9a9a9a;
}

@media (max-width: 720px) {
  .resource-hero h1 {
    font-size: 1.55rem;
  }

  .resource-notice {
    display: block;
  }

  .resource-notice strong {
    display: block;
    margin-bottom: 4px;
  }

  .resource-section-head {
    grid-template-columns: 1fr;
    gap: 10px;
  }

  .resource-list {
    grid-template-columns: 1fr;
  }
}
</style>
