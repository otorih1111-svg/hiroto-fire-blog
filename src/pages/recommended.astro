---
import BaseLayout from '../layouts/BaseLayout.astro';

const LINE_URL = import.meta.env.PUBLIC_LINE_URL || 'https://line.me/R/ti/p/%40103khwdx';

const sections = [
  {
    title: '自己アフィリ・ASP',
    note: '副業を始めたばかりの人が、お金の流れを小さく体験しやすいところから見ています。',
    services: [
      {
        name: 'ハピタス',
        body: '自己アフィリエイトを知る入口として調べました。報酬額より、成果条件と否認条件を読む練習になると感じています。',
        href: 'https://hapitas.jp/appinvite?i=25519472&route=pcText',
        label: 'ハピタスに登録する',
        sponsored: true,
      },
      {
        name: 'A8.net',
        body: '案件数が多く、ASPの管理画面や提携申請の流れを理解するために見ています。最初は案件の多さにかなり迷いました。',
        href: 'https://px.a8.net/svt/ejp?a8mat=35AXS6+691W7U+0K+10FXXU',
        label: 'A8.netを見てみる',
        sponsored: true,
      },
      {
        name: 'afb',
        body: 'A8とは違う案件や条件を見るために登録しました。確定率やEPCなど、案件選びの数字を見る練習にもなります。',
        href: '',
        label: '',
        sponsored: true,
      },
      {
        name: 'もしもアフィリエイト',
        body: '物販やブログ収益化を考えるときに候補に入れています。まずは仕組みを理解する目的で調べています。',
        href: '',
        label: '',
        sponsored: true,
      },
    ],
  },
  {
    title: '家計改善',
    note: '離婚後に家計を見直したとき、固定費を下げることは副業資金を作ることと同じだと感じました。',
    services: [
      {
        name: '格安SIM',
        body: '毎月の通信費は一度見直すと効果が続く固定費です。家計を小さく整える候補として優先度を高く見ています。',
        href: 'https://www.iijmio.jp/',
        label: '格安SIMを比較する',
      },
      {
        name: '楽天カード',
        body: '生活費の支払いとポイント管理をまとめる候補として調べています。使いすぎ防止も含めて考える必要があります。',
        href: 'https://www.rakuten-card.co.jp/',
        label: '楽天カード公式を見る',
      },
      {
        name: '家計簿アプリ',
        body: '副業より先に、毎月どこにお金が出ているかを見える化するために必要だと感じました。',
        href: 'https://moneyforward.com/',
        label: '家計簿アプリを見る',
      },
      {
        name: 'ふるさと納税',
        body: '食費や日用品の負担を少しでも下げられるか、シングル父の家計目線で調べています。',
        href: 'https://event.rakuten.co.jp/furusato/',
        label: 'ふるさと納税を見る',
      },
    ],
  },
  {
    title: '副業環境',
    note: '限られた時間で作業するために、道具選びはかなり大事でした。高いものを買うより、続けやすくなるかで見ています。',
    services: [
      {
        name: 'MacBook',
        body: '副業用の作業環境として使っています。記事作成、画像生成、AI操作をまとめてできるのが助かっています。',
        href: 'https://www.apple.com/jp/macbook-air/',
        label: 'MacBookを見る',
      },
      {
        name: 'Canva',
        body: '画像や資料づくりで使いやすい候補です。デザインが苦手でも最低限の見た目を整えやすいと感じています。',
        href: 'https://www.canva.com/ja_jp/',
        label: 'Canvaを見る',
      },
      {
        name: 'ChatGPT / Claude / Codex',
        body: '記事の下書き、構成、コード修正で使っています。丸投げではなく、考える時間を短縮する道具として見ています。',
        href: 'https://openai.com/chatgpt',
        label: 'AIツールの入口を見る',
      },
      {
        name: 'ブログ用サーバー',
        body: 'WordPressで始める人には必要な項目です。ぼくのサイトは別構成ですが、ブログ運営の選択肢として調べています。',
        href: 'https://www.xserver.ne.jp/',
        label: 'ブログ用サーバーを見る',
      },
    ],
  },
  {
    title: '投資・証券（慎重に）',
    note: 'お金に関わる領域なので、断定はしません。少額で調べたこと、注意したいことを中心に整理します。',
    services: [
      {
        name: '楽天証券',
        body: 'NISAや資産形成を調べる中で候補に入るサービスです。生活防衛資金を先に考えたうえで見ています。',
        href: 'https://www.rakuten-sec.co.jp/',
        label: '楽天証券を見る',
      },
      {
        name: 'SBI証券',
        body: '証券口座を比較するときによく名前が出ます。手数料や使いやすさを、初心者目線で確認したい項目です。',
        href: 'https://www.sbisec.co.jp/',
        label: 'SBI証券を見る',
      },
      {
        name: 'GMOクリック証券',
        body: 'FXや証券口座の候補として調べています。リスクがあるため、すすめるより先に注意点を整理します。',
        href: 'https://click-sec.com/',
        label: 'GMOクリック証券を見る',
      },
    ],
  },
  {
    title: '保険・FP相談（慎重に）',
    note: 'シングル父として、もしもの備えは避けて通れません。ただし不安を煽らず、必要性を落ち着いて見ます。',
    services: [
      {
        name: '保険相談',
        body: '子どもがいる家庭として、保障が足りているかを確認する候補です。入りすぎない視点も大事にします。',
        href: 'https://hoken-com.com/',
        label: '保険相談の候補を見る',
      },
      {
        name: 'FP相談',
        body: '家計、教育費、老後資金を一度整理するための相談先として見ています。答えを丸投げしない前提で使いたいです。',
        href: 'https://px.a8.net/svt/ejp?a8mat=4B3MEP+DK7HLM+5MAS+5YJRM',
        label: 'FP相談を見てみる',
        sponsored: true,
      },
    ],
  },
];
---

<BaseLayout
  title="40代シングル父の家計と副業を支えるサービス一覧"
  description="40代シングル父のひろとが、固定費を下げて副業資金を作るために調べたサービスを実体験ベースで整理しています。"
>
  <div class="recommended-page">
    <nav class="breadcrumb">
      <a href="/">トップ</a>
      <span>›</span>
      <span>おすすめサービス</span>
    </nav>

    <header class="recommended-hero">
      <p class="recommended-eyebrow">Service List</p>
      <h1>40代シングル父の家計と副業を支えるサービス一覧</h1>
      <p>
        離婚後、家計を全部見直したときに思ったのは「副業で増やす前に、出ていくお金を整えないときつい」ということでした。
        ここでは、ぼくが調べたもの、使ったもの、これから比較したいものをまとめます。
        実際に使ったもの、比較したもの、これから深掘りしたいものを、生活目線で整理しています。
      </p>
    </header>

    <div class="review-notice">
      <strong>現在の方針</strong>
      <span>おすすめ断定ではなく、40代シングル父の生活と副業に合うかを実録ベースで整理します。</span>
    </div>

    <div class="service-sections">
      {sections.map((section, index) => (
        <section class="service-section">
          <div class="service-section-head">
            <span class="service-index">{String(index + 1).padStart(2, '0')}</span>
            <div>
              <h2>{section.title}</h2>
              <p>{section.note}</p>
            </div>
          </div>
          <div class="service-list">
            {section.services.map(service => (
              <article class="service-item">
                <h3>{service.name}</h3>
                <p>{service.body}</p>
                {service.sponsored ? (
                  <>
                    <a
                      href={service.href}
                      class="service-link"
                      target="_blank"
                      rel="nofollow sponsored noopener noreferrer"
                    >
                      {service.label}
                    </a>
                  </>
                ) : (
                  <a
                    href={service.href}
                    class="service-link"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    {service.label}
                  </a>
                )}
              </article>
            ))}
          </div>
        </section>
      ))}
    </div>

    <section class="recommended-closing">
      <h2>詳しい体験談はこれから整理します</h2>
      <p>
        どれを使ったか、どこで迷ったか、失敗しそうになった点は、記事とLINEのPDFにまとめていきます。
        まずは自分の家計と副業に本当に必要だったものだけ、正直に残していきます。
      </p>
      <a href={LINE_URL} target="_blank" rel="noopener noreferrer" class="line-cta-link">LINEでPDFを受け取る</a>
    </section>
  </div>
</BaseLayout>

<style>
.recommended-page {
  max-width: 920px;
  margin: 0 auto;
}

.recommended-hero {
  padding: 34px 0 28px;
  border-bottom: 1px solid var(--color-border);
}

.recommended-eyebrow {
  display: inline-block;
  margin-bottom: 10px;
  padding: 4px 10px;
  background: var(--color-accent-light);
  color: var(--color-accent);
  font-size: 0.78rem;
  font-weight: 700;
}

.recommended-hero h1 {
  margin: 0 0 16px;
  font-size: 2rem;
  line-height: 1.45;
  letter-spacing: 0;
}

.recommended-hero p {
  max-width: 760px;
  color: var(--color-text-muted);
  line-height: 1.9;
}

.review-notice {
  display: flex;
  gap: 12px;
  align-items: flex-start;
  margin: 24px 0;
  padding: 16px 18px;
  border-left: 4px solid var(--color-accent);
  background: #f7fbf3;
  line-height: 1.8;
}

.review-notice strong {
  flex: 0 0 auto;
  color: var(--color-accent);
}

.service-sections {
  display: grid;
  gap: 34px;
}

.service-section {
  padding: 26px 0 30px;
  border-bottom: 1px solid var(--color-border);
}

.service-section-head {
  display: grid;
  grid-template-columns: 54px 1fr;
  gap: 18px;
  align-items: start;
  margin-bottom: 18px;
}

.service-index {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 48px;
  height: 48px;
  border: 1px solid var(--color-accent);
  color: var(--color-accent);
  font-weight: 700;
}

.service-section h2 {
  margin: 0 0 8px;
  font-size: 1.35rem;
  letter-spacing: 0;
}

.service-section-head p {
  color: var(--color-text-muted);
  line-height: 1.8;
}

.service-list {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12px;
}

.service-item {
  border: 1px solid var(--color-border);
  border-radius: 8px;
  padding: 18px;
  background: #fff;
}

.service-item h3 {
  margin: 0 0 10px;
  color: var(--color-text);
  font-size: 1rem;
  letter-spacing: 0;
}

.service-item p {
  color: var(--color-text-muted);
  font-size: 0.92rem;
  line-height: 1.8;
}

.service-link,
.line-cta-link {
  display: inline-block;
  margin-top: 12px;
  color: var(--color-accent);
  font-weight: 700;
}

.recommended-closing {
  padding: 34px 0 10px;
}

.recommended-closing h2 {
  margin: 0 0 12px;
  font-size: 1.35rem;
  letter-spacing: 0;
}

.recommended-closing p {
  color: var(--color-text-muted);
  line-height: 1.9;
}

@media (max-width: 720px) {
  .recommended-hero h1 {
    font-size: 1.55rem;
  }

  .review-notice {
    display: block;
  }

  .review-notice strong {
    display: block;
    margin-bottom: 4px;
  }

  .service-section-head {
    grid-template-columns: 1fr;
    gap: 10px;
  }

  .service-list {
    grid-template-columns: 1fr;
  }
}
</style>
