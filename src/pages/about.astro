---
import BaseLayout from '../layouts/BaseLayout.astro';

const redirectTarget = '/blog/about-hiroto/';
---

<BaseLayout
  title="記事を移動しました"
  description="プロフィールページはブログ記事へ移動しました。"
>
  <meta http-equiv="refresh" content={`0;url=${redirectTarget}`} />
  <div class="container" style="padding: 4rem 1rem; max-width: 720px;">
    <h1>プロフィールページを移動しました</h1>
    <p>
      このページは
      <a href={redirectTarget}>新しいプロフィール記事</a>
      へ移動しました。
    </p>
  </div>
</BaseLayout>
