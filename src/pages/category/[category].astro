---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const categories = ['節約・家計', '投資・FIRE', '副業・AI'];
  return categories.map(category => ({
    params: { category },
    props: { categoryName: category },
  }));
}

const { categoryName } = Astro.props;

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts
  .filter(post => post.data.category === categoryName)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const categoryMeta: Record<string, { emoji: string; desc: string; lead: string }> = {
  '節約・家計': {
    emoji: '💰',
    desc: '固定費・格安SIM・家計簿・ポイ活など、毎月の支出を整えるための記事一覧です。',
    lead: '固定費を削って毎月の手残りを増やす。ハピタス・格安SIM・保険見直しなど、40代シングル父が実際にやった節約と家計管理の記録です。まず「見える化」から始める人向けの記事を集めています。',
  },
  '投資・FIRE': {
    emoji: '📈',
    desc: '新NISA・iDeCo・FP相談・資産公開など、FIREに向けた資産形成の記録一覧です。',
    lead: '楽天証券でオルカンを積み立てながらFIREを目指す40代シングル父の記録。資産公開・NISA積立・FP無料相談など、「いつかやろう」を「今月から動く」に変えるための記事を集めています。',
  },
  '副業・AI': {
    emoji: '🤖',
    desc: '副業の始め方・AI活用・ブログ運営・自己アフィリなど、稼ぐ仕組みをつくる記事一覧です。',
    lead: '収益ゼロから始めた副業の試行錯誤をリアルに発信。ハピタス自己アフィリ・ブログ収益化・AIを使った時短術など、40代会社員が夜の1時間で動ける副業ノウハウを集めています。',
  },
};

const meta = categoryMeta[categoryName] ?? { emoji: '📝', desc: `${categoryName}に関する記事一覧`, lead: '' };
---

<BaseLayout
  title={`${meta.emoji} ${categoryName}の記事一覧`}
  description={meta.desc}
>
  <div class="container">

    <!-- パンくずリスト -->
    <nav class="breadcrumb">
      <a href="/">トップ</a>
      <span>›</span>
      <span>{categoryName}</span>
    </nav>

    <div class="page-title">
      <span class="category-badge" style="font-size: 0.82rem; margin-bottom: 12px; display: inline-block;">
        {meta.emoji} {categoryName}
      </span>
      <h1>{categoryName}の記事一覧（{posts.length}件）</h1>
      <p style="color: var(--color-text-muted); font-size: 0.9rem; line-height: 1.7; margin-top: 8px;">{meta.lead}</p>
    </div>

    {posts.length > 0 ? (
      <div class="article-grid">
        {posts.map(post => (
          <ArticleCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            category={post.data.category}
            slug={post.id}
            image={post.data.ogImage ?? post.data.image}
          />
        ))}
      </div>
    ) : (
      <div class="empty-state">
        <p style="font-size: 2rem; margin-bottom: 12px;">📝</p>
        <p>このカテゴリの記事はまもなく公開します。</p>
      </div>
    )}

  </div>
</BaseLayout>
