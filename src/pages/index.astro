---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const categories = [
  { name: '副業実録',       emoji: '📝' },
  { name: 'AI活用',         emoji: '🤖' },
  { name: 'FIRE設計',       emoji: '🔥' },
  { name: 'シングル父の日常', emoji: '👨‍👦' },
  { name: '買ってよかった',  emoji: '🛒' },
];
---

<BaseLayout title="ひろとの副業実録" description="40代シングル父がAIと副業でFIREを目指す過程をリアルに発信するブログ。">

  <!-- サイト概要（コンパクト） -->
  <section class="top-intro">
    <div class="top-intro-inner">
      <div class="top-intro-icon">🌱</div>
      <div>
        <h2 class="top-intro-title">「子どもに、お金で諦めたと言わせたくない」</h2>
        <p class="top-intro-desc">
          40代・シングル父がAIと副業でFIREを目指す過程をリアルに発信。
          成果なし・失敗も正直に書いています。
        </p>
      </div>
    </div>
  </section>

  <!-- カテゴリ -->
  <section class="category-nav">
    {categories.map(cat => (
      <a href={`/category/${cat.name}/`} class="cat-link">
        <span class="cat-link-emoji">{cat.emoji}</span>
        {cat.name}
      </a>
    ))}
  </section>

  <!-- 新着記事 -->
  <section>
    <h2 class="section-title" style="margin-bottom: 0;">新着記事</h2>
    {posts.length > 0 ? (
      <div class="article-list">
        {posts.map(post => (
          <ArticleCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            category={post.data.category}
            slug={post.id}
            image={post.data.image}
          />
        ))}
      </div>
    ) : (
      <div class="empty-state">
        <p style="font-size: 2rem; margin-bottom: 10px;">📝</p>
        <p>まもなく記事を公開します。</p>
      </div>
    )}
  </section>

</BaseLayout>

<style>
/* サイト概要 */
.top-intro {
  background: var(--color-accent-light);
  border: 1px solid rgba(45,122,79,0.15);
  border-radius: var(--radius);
  padding: 20px;
  margin-bottom: 20px;
}

.top-intro-inner {
  display: flex;
  gap: 14px;
  align-items: flex-start;
}

.top-intro-icon {
  font-size: 2rem;
  flex-shrink: 0;
  line-height: 1;
  margin-top: 2px;
}

.top-intro-title {
  font-size: 1rem;
  font-weight: 700;
  line-height: 1.5;
  margin-bottom: 5px;
  color: var(--color-text);
}

.top-intro-desc {
  font-size: 0.82rem;
  color: var(--color-text-muted);
  line-height: 1.7;
}

/* カテゴリナビ */
.category-nav {
  display: flex;
  gap: 6px;
  flex-wrap: wrap;
  margin-bottom: 20px;
}

.cat-link {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 5px 13px;
  border-radius: 3px;
  background: var(--color-bg-sub);
  border: 1px solid var(--color-border);
  color: var(--color-text);
  font-size: 0.78rem;
  font-weight: 500;
  text-decoration: none;
  transition: all 0.15s;
}

.cat-link:hover {
  background: var(--color-accent);
  border-color: var(--color-accent);
  color: #fff;
  text-decoration: none;
}

.cat-link-emoji {
  font-size: 0.9rem;
}

@media (max-width: 480px) {
  .top-intro-inner { flex-direction: column; gap: 8px; }
  .top-intro-icon { font-size: 1.5rem; }
}
</style>
