---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const MAIL_URL = import.meta.env.PUBLIC_MAIL_URL || 'https://mail.os7.biz/add/0B3Y';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const featuredDescriptions = {
  '2026-05-16-fire': 'お金から目を逸らしてきた人へ',
  'hajimete-no-fukugyo': '成果が出なくて迷っている人へ',
  'nisa-tsumitate-40dai': '投資・NISAを始めたい人へ',
};

const featuredSlugs = [
  '2026-05-16-fire',
  'hajimete-no-fukugyo',
  'nisa-tsumitate-40dai',
];

const featuredPosts = featuredSlugs
  .map((slug) => posts.find((post) => post.id === slug || post.data.slug === slug))
  .filter(Boolean);

const categories = [
  { name: '節約・家計', emoji: '💰' },
  { name: '投資・FIRE', emoji: '📈' },
  { name: '副業・AI',   emoji: '🤖' },
];

const topicLinks = [
  { label: '節約・家計（固定費を見直す）', href: '/category/節約・家計/' },
  { label: '投資・FIRE（増やす）',       href: '/category/投資・FIRE/' },
  { label: '副業・AI（稼ぐ）',           href: '/category/副業・AI/' },
];
---

<BaseLayout title="ひろとの家計改善とFIREブログ" description="40代シングルファーザーのひろとが、家計改善と資産づくりを通じてFIREを目指すブログ。固定費見直し、新NISA、楽天経済圏の体験談を正直に発信しています。">

  <!-- ヒーロー -->
  <section class="hero-cta">
    <div class="hero-cta-text">
      <p class="hero-cta-tag">節約 → 投資 → 副業の実録</p>
      <h1 class="hero-cta-title">
        お金の不安は、<br>「順番」で減らせる。
      </h1>
      <p class="hero-cta-desc">
        息子にお金で遠慮させないために。40代シングルファーザーのひろとが、月1万円の余白を作るところから投資・副業まで、遠回りも失敗も含めて正直に発信しています。
      </p>
      <p class="hero-cta-pdf-label">
        登録特典：「毎月1万円を浮かせるために最初にやったこと」
      </p>
      <div class="hero-cta-btns">
        <a href={MAIL_URL} target="_blank" rel="noopener noreferrer" class="hero-mail-btn">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="4" width="20" height="16" rx="2"/>
            <path d="m2 7 10 6 10-6"/>
          </svg>
          毎月1万円浮かせるメルマガに登録
        </a>
        <a href="/blog/about-hiroto/" class="hero-sub-btn">プロフィールを見る</a>
      </div>
      <p class="hero-cta-note">特典PDFは登録後すぐ。浮かせたあとのNISAまで7日間で届きます。解除はいつでも。</p>
    </div>
  </section>

  <section class="guide-grid">
    <article class="guide-card intro-card">
      <p class="guide-kicker">はじめての方へ</p>
      <h2 class="guide-title">まずは自己紹介からどうぞ</h2>
      <p class="guide-desc">
        離婚後に息子と2人暮らしになってから、なぜAIと副業でFIREを目指すようになったのかをまとめています。
      </p>
      <a href="/blog/about-hiroto/" class="guide-link">自己紹介記事を読む</a>
    </article>

    <article class="guide-card featured-card">
      <p class="guide-kicker">まず読んでほしい3記事</p>
      <div class="featured-list">
        {featuredPosts.map((post, index) => (
          <a href={`/blog/${post.id}/`} class="featured-item">
            <span class="featured-rank">{index + 1}</span>
            <span>
              <span class="featured-copy">{post.data.title}</span>
              <span class="featured-note">{featuredDescriptions[post.id]}</span>
            </span>
          </a>
        ))}
      </div>
    </article>
  </section>

  <section class="topic-nav">
    <div class="topic-nav-header">
      <h2 class="section-title" style="margin-bottom: 0;">カテゴリから読む</h2>
      <p class="topic-nav-desc">家計改善・投資・FIRE・シングルファーザーの暮らしの切り口で探せます。</p>
    </div>
    <div class="topic-link-list">
      {topicLinks.map((topic) => (
        <a href={topic.href} class="topic-link">{topic.label}</a>
      ))}
    </div>
  </section>

  <!-- カテゴリナビ -->
  <section class="category-nav">
    {categories.map(cat => (
      <a href={`/category/${cat.name}/`} class="cat-link">
        <span class="cat-link-emoji">{cat.emoji}</span>
        {cat.name}
      </a>
    ))}
  </section>

  <!-- 新着記事 -->
  <section>
    <h2 class="section-title" style="margin-bottom: 0;">新着記事</h2>
    {posts.length > 0 ? (
      <div class="article-list">
        {posts.map(post => (
          <ArticleCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            category={post.data.category}
            slug={post.id}
            image={post.data.ogImage ?? post.data.image}
          />
        ))}
      </div>
    ) : (
      <div class="empty-state">
        <p style="font-size: 2rem; margin-bottom: 10px;">📝</p>
        <p>まもなく記事を公開します。</p>
      </div>
    )}
  </section>

</BaseLayout>

<style>
/* ヒーローCTA */
.hero-cta {
  background:
    radial-gradient(circle at top right, rgba(45,122,79,0.12), transparent 32%),
    linear-gradient(135deg, #f7fcf9 0%, #eef8f2 100%);
  border: 1px solid rgba(45,122,79,0.14);
  border-radius: 24px;
  padding: 40px 32px;
  margin-bottom: 24px;
  display: flex;
  gap: 24px;
  align-items: center;
  box-shadow: 0 18px 42px rgba(29, 86, 55, 0.07);
}

.hero-cta-text {
  flex: 1;
  min-width: 0;
  max-width: 760px;
}

.hero-cta-tag {
  font-size: 0.7rem;
  letter-spacing: 0.08em;
  font-weight: 700;
  color: var(--color-accent);
  background: rgba(45,122,79,0.08);
  padding: 6px 12px;
  border-radius: 999px;
  display: inline-block;
  margin-bottom: 14px;
}

.hero-cta-title {
  font-size: 2.35rem;
  font-weight: 700;
  line-height: 1.28;
  letter-spacing: -0.03em;
  color: #21362b;
  margin-bottom: 14px;
}

.hero-cta-desc {
  font-size: 1.03rem;
  color: #5a7367;
  line-height: 1.9;
  margin-bottom: 18px;
}

.hero-cta-pdf-label {
  display: inline-block;
  font-size: 0.82rem;
  font-weight: 700;
  color: #1d5637;
  background: rgba(45,122,79,0.1);
  border: 1px solid rgba(45,122,79,0.18);
  border-radius: 8px;
  padding: 6px 12px;
  margin-bottom: 14px;
}

.hero-cta-desc strong {
  color: var(--color-accent);
  font-weight: 700;
}

.hero-cta-btns {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
  margin-bottom: 10px;
}

.hero-mail-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: linear-gradient(135deg, #2d7a4f 0%, #246744 55%, #1c5235 100%);
  color: #fff;
  font-weight: 700;
  font-size: 1rem;
  padding: 14px 24px;
  border-radius: 16px;
  border: 1px solid rgba(255,255,255,0.08);
  text-decoration: none;
  box-shadow: 0 14px 30px rgba(45,122,79,0.2);
  transition: transform 0.15s, box-shadow 0.15s, background 0.15s;
}

.hero-mail-btn:hover {
  background: linear-gradient(135deg, #2b734a 0%, #215f3f 55%, #18492f 100%);
  transform: translateY(-2px);
  box-shadow: 0 18px 34px rgba(45,122,79,0.24);
  text-decoration: none;
  color: #fff;
}

.hero-sub-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 14px 20px;
  border-radius: 16px;
  border: 1px solid rgba(45,122,79,0.14);
  background: rgba(255,255,255,0.75);
  color: #466255;
  font-size: 0.92rem;
  font-weight: 600;
  text-decoration: none;
  transition: border-color 0.15s, color 0.15s, background 0.15s;
}

.hero-sub-btn:hover {
  border-color: var(--color-accent);
  color: var(--color-accent);
  background: rgba(255,255,255,0.95);
  text-decoration: none;
}

.hero-cta-note {
  font-size: 0.78rem;
  color: #6f877a;
}

.guide-grid {
  display: grid;
  grid-template-columns: 1fr 1.2fr;
  gap: 16px;
  margin-bottom: 20px;
}

.guide-card {
  background: #fff;
  border: 1px solid var(--color-border);
  border-radius: 8px;
  padding: 20px;
}

.guide-kicker {
  font-size: 0.72rem;
  font-weight: 700;
  color: var(--color-accent);
  margin-bottom: 8px;
}

.guide-title {
  font-size: 1.15rem;
  margin-bottom: 8px;
}

.guide-desc,
.topic-nav-desc {
  font-size: 0.85rem;
  line-height: 1.7;
  color: var(--color-text-muted);
}

.guide-link {
  display: inline-flex;
  margin-top: 12px;
  font-weight: 700;
  color: var(--color-accent);
  text-decoration: none;
}

.guide-link:hover {
  text-decoration: underline;
}

.featured-list {
  display: grid;
  gap: 10px;
}

.featured-item {
  display: grid;
  grid-template-columns: 28px 1fr;
  gap: 10px;
  align-items: start;
  padding: 12px 14px;
  border-radius: 6px;
  background: var(--color-bg-sub);
  border: 1px solid var(--color-border);
  color: var(--color-text);
  text-decoration: none;
  transition: border-color 0.15s, transform 0.15s;
}

.featured-item:hover {
  border-color: var(--color-accent);
  transform: translateY(-1px);
  text-decoration: none;
}

.featured-rank {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 28px;
  height: 28px;
  border-radius: 999px;
  background: var(--color-accent);
  color: #fff;
  font-size: 0.8rem;
  font-weight: 700;
}

.featured-copy {
  display: block;
  font-size: 0.9rem;
  line-height: 1.5;
}

.featured-note {
  display: block;
  margin-top: 4px;
  font-size: 0.76rem;
  line-height: 1.5;
  color: var(--color-text-muted);
}

.topic-nav {
  margin-bottom: 20px;
}

.topic-nav-header {
  display: flex;
  justify-content: space-between;
  align-items: end;
  gap: 16px;
  margin-bottom: 10px;
}

.topic-link-list {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.topic-link {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8px 14px;
  border-radius: 999px;
  border: 1px solid var(--color-border);
  background: #fff;
  color: var(--color-text);
  text-decoration: none;
  font-size: 0.82rem;
  font-weight: 600;
  transition: border-color 0.15s, color 0.15s, background 0.15s;
}

.topic-link:hover {
  border-color: var(--color-accent);
  color: var(--color-accent);
  background: var(--color-accent-light);
  text-decoration: none;
}

/* カテゴリナビ */
.category-nav {
  display: flex;
  gap: 6px;
  flex-wrap: wrap;
  margin-bottom: 20px;
}

.cat-link {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 5px 13px;
  border-radius: 3px;
  background: var(--color-bg-sub);
  border: 1px solid var(--color-border);
  color: var(--color-text);
  font-size: 0.78rem;
  font-weight: 500;
  text-decoration: none;
  transition: all 0.15s;
}

.cat-link:hover {
  background: var(--color-accent);
  border-color: var(--color-accent);
  color: #fff;
  text-decoration: none;
}

.cat-link-emoji { font-size: 0.9rem; }








@media (max-width: 640px) {
  .hero-cta {
    padding: 28px 20px;
    border-radius: 20px;
  }
  .hero-cta-title { font-size: 1.75rem; }
  .hero-cta-desc { font-size: 0.92rem; }
  .hero-mail-btn,
  .hero-sub-btn {
    width: 100%;
  }
  .guide-grid {
    grid-template-columns: 1fr;
  }
  .topic-nav-header {
    flex-direction: column;
    align-items: start;
  }
}
</style>
