---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const featuredPosts = posts.slice(0, 6);

const categories = [
  { name: '副業実録', emoji: '📝' },
  { name: 'AI活用', emoji: '🤖' },
  { name: 'FIRE設計', emoji: '🔥' },
  { name: 'シングル父の日常', emoji: '👨‍👦' },
  { name: '買ってよかった', emoji: '🛒' },
];
---

<BaseLayout title="ひろとの副業実録" description="40代シングル父がAIと副業でFIREを目指す過程をリアルに発信するブログ。">

  <!-- ヒーローセクション -->
  <section style="background: linear-gradient(135deg, #1a1a1a 0%, #333 100%); color: #fff; padding: 60px 0 50px;">
    <div class="container" style="text-align: center;">
      <p style="font-size: 0.82rem; background: rgba(255,255,255,0.15); display: inline-block; padding: 4px 14px; border-radius: 20px; margin-bottom: 16px;">40代・シングル父・FIRE目指す会社員</p>
      <h1 style="font-size: 2rem; font-weight: 700; line-height: 1.4; margin-bottom: 16px;">
        息子に「お金で諦めた」と<br>言わせたくない
      </h1>
      <p style="font-size: 0.95rem; opacity: 0.85; max-width: 500px; margin: 0 auto 24px; line-height: 1.8;">
        離婚を経て10歳の息子を育てながら、AIと副業でFIREを目指す過程をリアルに発信しています。
        失敗も成果なしも正直に書きます。
      </p>
      <div style="display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;">
        <a href="/profile/" style="background: #fff; color: #1a1a1a; font-weight: 700; padding: 12px 24px; border-radius: 6px; font-size: 0.9rem; text-decoration: none;">ひろとについて</a>
        <a href="https://lin.ee/XXXXXXXX" target="_blank" rel="noopener noreferrer"
           style="background: #00b900; color: #fff; font-weight: 700; padding: 12px 24px; border-radius: 6px; font-size: 0.9rem; text-decoration: none;">
          📩 LINE登録（無料レポート）
        </a>
      </div>
    </div>
  </section>

  <!-- カテゴリナビ -->
  <section style="background: #f8f9fa; padding: 28px 0; border-bottom: 1px solid #e0e0e0;">
    <div class="container">
      <div style="display: flex; gap: 12px; flex-wrap: wrap; justify-content: center;">
        {categories.map(cat => (
          <a href={`/category/${cat.name}/`}
             class={`category-badge category-${cat.name}`}
             style="font-size: 0.88rem; padding: 8px 20px;">
            {cat.emoji} {cat.name}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- 新着記事 -->
  <section style="padding: 48px 0;">
    <div class="container">
      <div style="display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 24px;">
        <h2 style="font-size: 1.25rem; font-weight: 700;">新着記事</h2>
      </div>

      {featuredPosts.length > 0 ? (
        <div class="article-grid">
          {featuredPosts.map(post => (
            <ArticleCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              category={post.data.category}
              slug={post.id}
            />
          ))}
        </div>
      ) : (
        <div class="empty-state">
          <p style="font-size: 2rem; margin-bottom: 12px;">📝</p>
          <p>まもなく記事を公開します。</p>
        </div>
      )}
    </div>
  </section>

  <!-- プロフィール紹介 -->
  <section style="background: #f8f9fa; padding: 48px 0; border-top: 1px solid #e0e0e0;">
    <div class="container">
      <div style="max-width: 600px; margin: 0 auto; text-align: center;">
        <div style="font-size: 3rem; margin-bottom: 16px;">👨‍👦</div>
        <h2 style="font-size: 1.2rem; font-weight: 700; margin-bottom: 12px;">書いている人：ひろと</h2>
        <p style="font-size: 0.9rem; line-height: 1.8; color: #444; margin-bottom: 20px;">
          40代・千葉県在住・シングル父。10歳の息子のためにFIREを目指し、会社員をしながら副業×AIに挑戦中。
          成果なし・試行錯誤の過程を正直に発信しています。
        </p>
        <a href="/profile/" style="font-size: 0.88rem; color: #1a73e8;">詳しいプロフィールを見る →</a>
      </div>
    </div>
  </section>

</BaseLayout>
