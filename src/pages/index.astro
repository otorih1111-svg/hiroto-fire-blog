---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const MAIL_URL = import.meta.env.PUBLIC_MAIL_URL || 'https://mail.os7.biz/add/0B3Y';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const featuredDescriptions = {
  '2026-06-10-kakei-kaizen-roadmap': '何から始めるか迷っている人へ',
  '2026-05-21-fp-sodan-review': 'お金の不安を1時間で整理したい人へ',
  'nisa-tsumitate-40dai': '投資・NISAを始めたい人へ',
};

const featuredSlugs = [
  '2026-06-10-kakei-kaizen-roadmap',
  '2026-05-21-fp-sodan-review',
  'nisa-tsumitate-40dai',
];

const featuredPosts = featuredSlugs
  .map((slug) => posts.find((post) => post.id === slug || post.data.slug === slug))
  .filter(Boolean);

const orderSteps = [
  {
    step: 'STEP 1',
    power: '貯める',
    title: '節約・家計',
    sub: '固定費を見直して、毎月の余白を作る',
    desc: '最初にやるのは節約でも我慢でもなく、固定費の見直し。ぼくはここで月1万円以上の余白ができました。',
    hubHref: '/blog/2026-06-10-kakei-kaizen-roadmap/',
    hubLabel: '家計改善ロードマップを読む',
    catHref: '/category/節約・家計/',
    img: '/images/characters/hiroto/hiroto-character-memo.png',
    imgAlt: 'メモを取るひろと',
    theme: 'theme-save',
  },
  {
    step: 'STEP 2',
    power: '増やす',
    title: '投資・FIRE',
    sub: '浮いたお金を、新NISAでコツコツ働かせる',
    desc: '余白ができたら、次は月1万円からの積立投資。40代からでも遅くなかった、が正直な結論です。',
    hubHref: '/blog/nisa-tsumitate-40dai/',
    hubLabel: '新NISA月1万円の結論を読む',
    catHref: '/category/投資・FIRE/',
    img: '/images/characters/hiroto/hiroto-character-confident.png',
    imgAlt: '自信ありげなひろと',
    theme: 'theme-invest',
  },
  {
    step: 'STEP 3',
    power: '稼ぐ',
    title: '副業・AI',
    sub: '収入の柱を増やす。ここは実録中',
    desc: '節約と投資が回り始めたら、最後に収入そのものを増やす挑戦。収益0円からの過程を隠さず書いています。',
    hubHref: '/blog/2026-05-21-fukugyo-first-10000-roadmap/',
    hubLabel: '最初の1万円を作る順番を読む',
    catHref: '/category/副業・AI/',
    img: '/images/characters/hiroto/hiroto-character-pc-work.png',
    imgAlt: 'パソコンで作業するひろと',
    theme: 'theme-earn',
  },
];
---

<BaseLayout title="ひろとの家計改善とFIREブログ" description="40代シングルファーザーのひろとが、家計改善と資産づくりを通じてFIREを目指すブログ。固定費見直し、新NISA、楽天経済圏の体験談を正直に発信しています。">

  <!-- ヒーロー -->
  <section class="hero-cta">
    <div class="hero-cta-text">
      <p class="hero-step-badges" aria-label="節約、投資、副業の順の実録">
        <span class="hero-badge badge-save">1 貯める</span>
        <span class="hero-badge-arrow">→</span>
        <span class="hero-badge badge-invest">2 増やす</span>
        <span class="hero-badge-arrow">→</span>
        <span class="hero-badge badge-earn">3 稼ぐ</span>
        <span class="hero-badge-label">の実録</span>
      </p>
      <h1 class="hero-cta-title">
        お金の不安は、<br>「順番」で減らせる。
      </h1>
      <p class="hero-cta-desc">
        息子にお金で遠慮させないために。40代シングルファーザーのひろとが、月1万円の余白を作るところから投資・副業まで、遠回りも失敗も含めて正直に発信しています。
      </p>
      <p class="hero-cta-pdf-label">
        登録特典：「毎月1万円を浮かせるために最初にやったこと」
      </p>
      <div class="hero-cta-btns">
        <a href={MAIL_URL} target="_blank" rel="noopener noreferrer" class="hero-mail-btn">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="4" width="20" height="16" rx="2"/>
            <path d="m2 7 10 6 10-6"/>
          </svg>
          毎月1万円浮かせるメルマガに登録
        </a>
        <a href="/blog/about-hiroto/" class="hero-sub-btn">プロフィールを見る</a>
      </div>
      <p class="hero-cta-note">特典PDFは登録後すぐ。浮かせたあとのNISAまで7日間で届きます。解除はいつでも。</p>
    </div>
    <div class="hero-cta-art" aria-hidden="true">
      <img src="/images/characters/family/family-character-together-laughing.png" alt="" width="230" height="230" loading="eager" />
    </div>
  </section>

  <section class="guide-grid">
    <article class="guide-card intro-card">
      <p class="guide-kicker">はじめての方へ</p>
      <h2 class="guide-title">まずは自己紹介からどうぞ</h2>
      <p class="guide-desc">
        離婚後に息子と2人暮らしになってから、なぜAIと副業でFIREを目指すようになったのかをまとめています。
      </p>
      <a href="/blog/about-hiroto/" class="guide-link">自己紹介記事を読む</a>
    </article>

    <article class="guide-card featured-card">
      <p class="guide-kicker">まず読んでほしい3記事</p>
      <div class="featured-list">
        {featuredPosts.map((post, index) => (
          <a href={`/blog/${post.id}/`} class="featured-item">
            <span class="featured-rank">{index + 1}</span>
            <span>
              <span class="featured-copy">{post.data.title}</span>
              <span class="featured-note">{featuredDescriptions[post.id]}</span>
            </span>
          </a>
        ))}
      </div>
    </article>
  </section>

  <section class="order-nav">
    <div class="order-nav-header">
      <h2 class="section-title" style="margin-bottom: 0;">「お金の順番」で学ぼう</h2>
      <p class="topic-nav-desc">貯める → 増やす → 稼ぐ。この順番で進めるのが、遠回りしたぼくの結論です。</p>
    </div>
    <div class="order-grid">
      {orderSteps.map((s) => (
        <article class={`order-card ${s.theme}`}>
          <a href={s.hubHref} class="order-banner">
            <span class="order-banner-text">
              <span class="order-step">{s.step}</span>
              <span class="order-power">{s.power}<span class="order-power-suffix">力</span></span>
              <span class="order-banner-sub">{s.sub}</span>
            </span>
            <img class="order-banner-img" src={s.img} alt={s.imgAlt} width="64" height="64" loading="lazy" />
          </a>
          <div class="order-body">
            <p class="order-desc">{s.desc}</p>
            <a href={s.hubHref} class="order-first">{s.hubLabel} →</a>
            <a href={s.catHref} class="order-cat">{s.title}の記事一覧 →</a>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- 新着記事 -->
  <section>
    <h2 class="section-title" style="margin-bottom: 0;">新着記事</h2>
    {posts.length > 0 ? (
      <div class="article-list">
        {posts.slice(0, 12).map(post => (
          <ArticleCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            category={post.data.category}
            slug={post.id}
            image={post.data.ogImage ?? post.data.image}
          />
        ))}
      </div>
    ) : (
      <div class="empty-state">
        <p style="font-size: 2rem; margin-bottom: 10px;">📝</p>
        <p>まもなく記事を公開します。</p>
      </div>
    )}
    {posts.length > 12 && (
      <div class="all-posts-wrap">
        <a href="/blog/" class="all-posts-link">すべての記事を見る（{posts.length}本） →</a>
      </div>
    )}
  </section>

</BaseLayout>

<style>
.all-posts-wrap {
  text-align: center;
  margin-top: 24px;
}

.all-posts-link {
  display: inline-block;
  padding: 10px 22px;
  border: 1px solid rgba(45,122,79,0.35);
  border-radius: 999px;
  color: var(--color-accent);
  font-weight: 600;
  font-size: 0.92rem;
  text-decoration: none;
  transition: background 0.15s ease;
}

.all-posts-link:hover {
  background: rgba(45,122,79,0.08);
}

/* ヒーローCTA */
.hero-cta {
  background:
    radial-gradient(circle at top right, rgba(45,122,79,0.12), transparent 32%),
    linear-gradient(135deg, #f7fcf9 0%, #eef8f2 100%);
  border: 1px solid rgba(45,122,79,0.14);
  border-radius: 24px;
  padding: 40px 32px;
  margin-bottom: 24px;
  display: flex;
  gap: 24px;
  align-items: center;
  box-shadow: 0 18px 42px rgba(29, 86, 55, 0.07);
}

.hero-cta-text {
  flex: 1;
  min-width: 0;
  max-width: 760px;
}

.hero-step-badges {
  display: flex;
  align-items: center;
  gap: 6px;
  flex-wrap: wrap;
  margin-bottom: 16px;
}

.hero-badge {
  display: inline-block;
  font-size: 0.78rem;
  font-weight: 800;
  color: #fff;
  padding: 5px 12px;
  border-radius: 999px;
  box-shadow: 0 3px 8px rgba(0,0,0,0.12);
}

.badge-save   { background: linear-gradient(135deg, #2d7a4f, #1c5235); }
.badge-invest { background: linear-gradient(135deg, #1f6e8c, #14506b); }
.badge-earn   { background: var(--color-cta-grad); }

.hero-badge-arrow {
  color: #7ba18d;
  font-weight: 700;
  font-size: 0.85rem;
}

.hero-badge-label {
  font-size: 0.78rem;
  font-weight: 700;
  color: #4a6a58;
  margin-left: 2px;
}

.hero-cta-art {
  flex-shrink: 0;
  align-self: flex-end;
  margin-bottom: -40px;
  position: relative;
}

.hero-cta-art::before {
  content: '';
  position: absolute;
  inset: 10px 6px 30px 6px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255,217,59,0.55), rgba(255,217,59,0) 70%);
  z-index: 0;
}

.hero-cta-art img {
  position: relative;
  z-index: 1;
  display: block;
  width: 230px;
  height: auto;
  filter: drop-shadow(0 10px 18px rgba(29,86,55,0.16));
}

.hero-cta-title {
  font-size: 2.35rem;
  font-weight: 700;
  line-height: 1.28;
  letter-spacing: -0.03em;
  color: #21362b;
  margin-bottom: 14px;
}

.hero-cta-desc {
  font-size: 1.03rem;
  color: #5a7367;
  line-height: 1.9;
  margin-bottom: 18px;
}

.hero-cta-pdf-label {
  display: inline-block;
  font-size: 0.82rem;
  font-weight: 700;
  color: #1d5637;
  background: linear-gradient(transparent 55%, rgba(255,217,59,0.75) 55%);
  border-radius: 4px;
  padding: 6px 4px;
  margin-bottom: 14px;
}

.hero-cta-desc strong {
  color: var(--color-accent);
  font-weight: 700;
}

.hero-cta-btns {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
  margin-bottom: 10px;
}

.hero-mail-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: var(--color-cta-grad);
  color: #fff;
  font-weight: 700;
  font-size: 1rem;
  padding: 14px 26px;
  border-radius: 999px;
  border: 1px solid rgba(255,255,255,0.2);
  text-decoration: none;
  box-shadow: 0 14px 30px rgba(239,127,26,0.32);
  transition: transform 0.15s, box-shadow 0.15s, filter 0.15s;
}

.hero-mail-btn:hover {
  filter: brightness(0.95);
  transform: translateY(-2px);
  box-shadow: 0 18px 34px rgba(239,127,26,0.38);
  text-decoration: none;
  color: #fff;
}

.hero-sub-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 14px 20px;
  border-radius: 16px;
  border: 1px solid rgba(45,122,79,0.14);
  background: rgba(255,255,255,0.75);
  color: #466255;
  font-size: 0.92rem;
  font-weight: 600;
  text-decoration: none;
  transition: border-color 0.15s, color 0.15s, background 0.15s;
}

.hero-sub-btn:hover {
  border-color: var(--color-accent);
  color: var(--color-accent);
  background: rgba(255,255,255,0.95);
  text-decoration: none;
}

.hero-cta-note {
  font-size: 0.78rem;
  color: #6f877a;
}

.guide-grid {
  display: grid;
  grid-template-columns: 1fr 1.2fr;
  gap: 16px;
  margin-bottom: 20px;
}

.guide-card {
  background: #fff;
  border: 1px solid var(--color-border);
  border-radius: 8px;
  padding: 20px;
}

.guide-kicker {
  font-size: 0.72rem;
  font-weight: 700;
  color: var(--color-accent);
  margin-bottom: 8px;
}

.guide-title {
  font-size: 1.15rem;
  margin-bottom: 8px;
}

.guide-desc,
.topic-nav-desc {
  font-size: 0.85rem;
  line-height: 1.7;
  color: var(--color-text-muted);
}

.guide-link {
  display: inline-flex;
  margin-top: 12px;
  font-weight: 700;
  color: var(--color-accent);
  text-decoration: none;
}

.guide-link:hover {
  text-decoration: underline;
}

.featured-list {
  display: grid;
  gap: 10px;
}

.featured-item {
  display: grid;
  grid-template-columns: 28px 1fr;
  gap: 10px;
  align-items: start;
  padding: 12px 14px;
  border-radius: 6px;
  background: var(--color-bg-sub);
  border: 1px solid var(--color-border);
  color: var(--color-text);
  text-decoration: none;
  transition: border-color 0.15s, transform 0.15s;
}

.featured-item:hover {
  border-color: var(--color-accent);
  transform: translateY(-1px);
  text-decoration: none;
}

.featured-rank {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 28px;
  height: 28px;
  border-radius: 999px;
  background: var(--color-accent);
  color: #fff;
  font-size: 0.8rem;
  font-weight: 700;
}

.featured-copy {
  display: block;
  font-size: 0.9rem;
  line-height: 1.5;
}

.featured-note {
  display: block;
  margin-top: 4px;
  font-size: 0.76rem;
  line-height: 1.5;
  color: var(--color-text-muted);
}

.order-nav {
  margin-bottom: 28px;
}

.order-nav-header {
  display: flex;
  justify-content: space-between;
  align-items: end;
  gap: 16px;
  margin-bottom: 14px;
}

.order-nav-header .section-title {
  flex-shrink: 0;
  white-space: nowrap;
}

.order-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
}

.order-card {
  background: #fff;
  border: 1px solid var(--color-border);
  border-radius: 12px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  transition: transform 0.15s, box-shadow 0.15s;
}

.order-card:hover {
  transform: translateY(-2px);
  box-shadow: 0 12px 28px rgba(29, 86, 55, 0.1);
}

.order-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
  padding: 20px 16px 16px 18px;
  color: #fff;
  text-decoration: none;
}

.order-banner-text {
  min-width: 0;
}

.order-banner-img {
  flex-shrink: 0;
  width: 64px;
  height: 64px;
  object-fit: contain;
  filter: drop-shadow(0 4px 8px rgba(0,0,0,0.18));
  background: rgba(255,255,255,0.92);
  border-radius: 50%;
  padding: 5px;
}

.order-banner:hover {
  text-decoration: none;
  color: #fff;
}

.theme-save .order-banner {
  background: linear-gradient(135deg, #2d7a4f 0%, #1c5235 100%);
}

.theme-invest .order-banner {
  background: linear-gradient(135deg, #1f6e8c 0%, #14506b 100%);
}

.theme-earn .order-banner {
  background: linear-gradient(135deg, #c77b28 0%, #a2601a 100%);
}

.order-step {
  display: inline-block;
  font-size: 0.68rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  background: rgba(255,255,255,0.18);
  border-radius: 999px;
  padding: 3px 10px;
  margin-bottom: 8px;
}

.order-power {
  display: block;
  font-size: clamp(1.25rem, 1.6vw, 1.6rem);
  font-weight: 800;
  line-height: 1.2;
  letter-spacing: 0.02em;
  white-space: nowrap;
}

.order-power-suffix {
  font-size: 1.1rem;
  font-weight: 700;
  margin-left: 2px;
}

.order-banner-sub {
  display: block;
  margin-top: 6px;
  font-size: 0.78rem;
  line-height: 1.5;
  color: rgba(255,255,255,0.88);
}

.order-body {
  padding: 14px 18px 18px;
  display: flex;
  flex-direction: column;
  gap: 8px;
  flex: 1;
}

.order-desc {
  font-size: 0.82rem;
  line-height: 1.7;
  color: var(--color-text-muted);
  flex: 1;
}

.order-first {
  display: inline-block;
  font-size: 0.8rem;
  font-weight: 700;
  color: var(--color-accent);
  text-decoration: none;
  border: 1px solid rgba(45,122,79,0.3);
  border-radius: 999px;
  padding: 7px 14px;
  text-align: center;
  transition: background 0.15s, border-color 0.15s;
}

.order-first:hover {
  background: rgba(45,122,79,0.08);
  border-color: var(--color-accent);
  text-decoration: none;
}

.order-cat {
  display: inline-block;
  font-size: 0.78rem;
  font-weight: 600;
  color: var(--color-text-muted);
  text-decoration: none;
  text-align: center;
}

.order-cat:hover {
  color: var(--color-accent);
  text-decoration: underline;
}

/* カテゴリナビ */








@media (max-width: 640px) {
  .hero-cta {
    padding: 28px 20px;
    border-radius: 20px;
  }
  .hero-cta-title { font-size: 1.75rem; }
  .hero-cta-desc { font-size: 0.92rem; }
  .hero-cta { flex-direction: column; }
  .hero-cta-art {
    align-self: center;
    margin-bottom: -28px;
  }
  .hero-cta-art img { width: 170px; }
  .hero-mail-btn,
  .hero-sub-btn {
    width: 100%;
  }
  .guide-grid {
    grid-template-columns: 1fr;
  }
  .order-nav-header {
    flex-direction: column;
    align-items: start;
  }
  .order-grid {
    grid-template-columns: 1fr;
  }
}
</style>
