---
// メルマガ登録CTAブロック（記事間・ページ内挿入用）
const MAIL_URL = import.meta.env.PUBLIC_MAIL_URL || 'https://mail.os7.biz/add/0B3Y';
---

<div class="mail-cta-block">
  <div class="mail-cta-inner">
    <div class="mail-cta-left">
      <span class="mail-cta-badge">📩 完全無料</span>
      <p class="mail-cta-title">「あと月1万円」を一緒に作りませんか？</p>
      <p class="mail-cta-desc">
        固定費を見直して<strong>月1万円以上浮いた話</strong>。月3,000円から月1万円に増やした話。AI副業で試行錯誤した話。<br>
        シングルファーザーのひろとが実際にやった「節約→投資→副業」の流れを、失敗込みで正直にメールで届けます。
      </p>
      <ul class="mail-cta-benefits">
        <li>✅ 節約・投資・副業のリアルな体験談が届く</li>
        <li>✅ 失敗・出費まで全部正直に公開</li>
        <li>✅ 登録は30秒・いつでも解除OK</li>
      </ul>
    </div>
    <div class="mail-cta-right">
      <a href={MAIL_URL} target="_blank" rel="noopener noreferrer" class="mail-cta-btn">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="4" width="20" height="16" rx="2"/>
          <path d="m2 7 10 6 10-6"/>
        </svg>
        メルマガに登録する（無料）
      </a>
    </div>
  </div>
</div>

<style>
.mail-cta-block {
  background: linear-gradient(135deg, #2d7a4f 0%, #1e5c39 100%);
  border-radius: 8px;
  padding: 24px;
  margin: 28px 0;
  color: #fff;
}

.mail-cta-inner {
  display: flex;
  gap: 24px;
  align-items: center;
}

.mail-cta-left { flex: 1; min-width: 0; }

.mail-cta-badge {
  display: inline-block;
  background: rgba(255,255,255,0.25);
  font-size: 0.72rem;
  font-weight: 700;
  padding: 3px 10px;
  border-radius: 20px;
  margin-bottom: 8px;
}

.mail-cta-title {
  font-size: 1rem;
  font-weight: 700;
  line-height: 1.5;
  margin-bottom: 8px;
}

.mail-cta-desc {
  font-size: 0.82rem;
  line-height: 1.7;
  opacity: 0.92;
  margin-bottom: 10px;
}

.mail-cta-desc strong { color: #fff; font-weight: 700; }

.mail-cta-benefits {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 3px;
}

.mail-cta-benefits li {
  font-size: 0.78rem;
  opacity: 0.92;
}

.mail-cta-right {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  gap: 12px;
}

.mail-cta-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: #fff;
  color: #1e5c39;
  font-weight: 700;
  font-size: 0.88rem;
  padding: 12px 18px;
  border-radius: 6px;
  white-space: nowrap;
  box-shadow: 0 4px 14px rgba(0,0,0,0.2);
  transition: transform 0.15s, box-shadow 0.15s;
  text-decoration: none;
}

.mail-cta-btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 6px 18px rgba(0,0,0,0.25);
  text-decoration: none;
  color: #14432a;
}

@media (max-width: 600px) {
  .mail-cta-inner { flex-direction: column; }
  .mail-cta-right { width: 100%; }
  .mail-cta-btn { justify-content: center; font-size: 0.85rem; padding: 13px 14px; }
}
</style>
