---
// メルマガ登録CTAブロック（記事間・ページ内挿入用）
const MAIL_URL = import.meta.env.PUBLIC_MAIL_URL || 'https://mail.os7.biz/add/0B3Y';
---

<div class="mail-cta-block">
  <div class="mail-cta-inner">
    <div class="mail-cta-left">
      <span class="mail-cta-badge">📩 登録特典あり</span>
      <p class="mail-cta-title">登録後すぐ受け取れます。「毎月1万円を浮かせるために最初にやったこと」</p>
      <p class="mail-cta-desc">
        楽天モバイル・楽天ひかり・楽天カード・楽天証券・保険の整理まで。<br>
        シングルファーザーのひろとが副業の前に家計を立て直した実体験を、PDFにまとめました。
      </p>
      <ul class="mail-cta-benefits">
        <li>✅ 登録後すぐ受け取れる特典PDFつき</li>
        <li>✅ 節約・投資・副業のリアルな体験談が届く</li>
        <li>✅ 失敗・出費まで全部正直に公開</li>
      </ul>
    </div>
    <div class="mail-cta-right">
      <a href={MAIL_URL} target="_blank" rel="noopener noreferrer" class="mail-cta-btn">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="4" width="20" height="16" rx="2"/>
          <path d="m2 7 10 6 10-6"/>
        </svg>
        毎月1万円浮かせるメルマガに登録
      </a>
    </div>
  </div>
</div>

<style>
.mail-cta-block {
  background: linear-gradient(135deg, #2d7a4f 0%, #246744 55%, #1c5235 100%);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 12px;
  padding: 24px;
  margin: 28px 0;
  color: #fff;
  box-shadow: 0 10px 24px rgba(30, 92, 57, 0.14);
}

.mail-cta-inner {
  display: flex;
  gap: 24px;
  align-items: center;
}

.mail-cta-left { flex: 1; min-width: 0; }

.mail-cta-badge {
  display: inline-block;
  background: rgba(255,255,255,0.18);
  border: 1px solid rgba(255,255,255,0.16);
  font-size: 0.72rem;
  font-weight: 700;
  padding: 3px 10px;
  border-radius: 20px;
  margin-bottom: 8px;
}

.mail-cta-title {
  font-size: 1rem;
  font-weight: 700;
  line-height: 1.5;
  margin-bottom: 8px;
}

.mail-cta-desc {
  font-size: 0.82rem;
  line-height: 1.7;
  opacity: 0.92;
  margin-bottom: 10px;
}

.mail-cta-desc strong { color: #fff; font-weight: 700; }

.mail-cta-benefits {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 3px;
}

.mail-cta-benefits li {
  font-size: 0.78rem;
  opacity: 0.92;
}

.mail-cta-right {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  gap: 12px;
}

.mail-cta-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: #fff;
  color: #1d5637;
  font-weight: 700;
  font-size: 0.88rem;
  padding: 13px 20px;
  border-radius: 999px;
  border: 1px solid rgba(20, 67, 42, 0.08);
  white-space: nowrap;
  box-shadow: 0 8px 22px rgba(0,0,0,0.18);
  transition: transform 0.15s, box-shadow 0.15s, color 0.15s;
  text-decoration: none;
}

.mail-cta-btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 12px 24px rgba(0,0,0,0.22);
  text-decoration: none;
  color: #14432a;
}

@media (max-width: 600px) {
  .mail-cta-inner { flex-direction: column; }
  .mail-cta-right { width: 100%; }
  .mail-cta-btn { justify-content: center; font-size: 0.85rem; padding: 13px 14px; }
}
</style>
