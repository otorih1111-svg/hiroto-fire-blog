---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  category: string;
  slug: string;
  image?: string;
}

const { title, description, pubDate, category, slug, image } = Astro.props;

const dateStr = pubDate.toLocaleDateString('ja-JP', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// イラスト風サムネ（public/thumbnails/{slug}.png）を優先。なければ指定画像
const thumbImage = image ?? `/thumbnails/${slug}.png`;
---

<a href={`/blog/${slug}/`} class="article-card">
  <!-- サムネイル（OGP自動生成 or 指定画像） -->
  <div class="article-thumb">
    <img src={thumbImage} alt={title} loading="lazy" />
  </div>
  <!-- 本文 -->
  <div class="article-card-body">
    <span class="article-card-category">{category}</span>
    <h2 class="article-card-title">{title}</h2>
    <p class="article-card-description">{description}</p>
    <p class="article-card-meta">{dateStr}</p>
  </div>
</a>
