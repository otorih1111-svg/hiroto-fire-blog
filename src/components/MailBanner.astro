---
// フッター上のフルバナー：メルマガ登録誘導
const MAIL_URL = import.meta.env.PUBLIC_MAIL_URL || 'https://mail.os7.biz/add/0B3Y';
---

<div class="mail-banner-full">
  <div class="mail-banner-full-inner">
    <div class="mail-banner-full-left">
      <span class="mail-banner-badge">FREE GUIDE</span>
      <p class="mail-banner-title">「あと月1万円」を作る流れを、無料で受け取りませんか</p>
      <p class="mail-banner-desc">固定費見直し、投資、副業の順で、シングルファーザーのひろとが実際にやった流れを、失敗込みで正直にまとめています。</p>
      <ul class="mail-banner-points">
        <li>登録後すぐPDFを受け取れる</li>
        <li>節約・投資・副業の流れをひとつにつなげて読める</li>
        <li>失敗や出費もきれいに盛らずにそのまま公開</li>
      </ul>
    </div>
    <div class="mail-banner-full-right">
      <a href={MAIL_URL} target="_blank" rel="noopener noreferrer" class="mail-banner-btn">
        <span class="mail-banner-btn-icon" aria-hidden="true">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="4" width="20" height="16" rx="2"/>
            <path d="m2 7 10 6 10-6"/>
          </svg>
        </span>
        誰でもできる月1万円ガイド
      </a>
      <p class="mail-banner-note">30秒で登録。固定費見直しの順番がすぐ分かります。</p>
    </div>
  </div>
</div>

<style>
.mail-banner-full {
  max-width: 1100px;
  margin: 56px auto 0;
  padding: 0 20px;
}
.mail-banner-full-inner {
  background:
    radial-gradient(circle at top right, rgba(45,122,79,0.12), transparent 30%),
    linear-gradient(180deg, #fbfdfb 0%, #f3faf6 100%);
  border: 1px solid rgba(45,122,79,0.15);
  border-radius: 26px;
  padding: 28px 30px;
  display: flex;
  align-items: flex-start;
  gap: 28px;
  box-shadow: 0 18px 42px rgba(29, 86, 55, 0.08);
}
.mail-banner-full-left { flex: 1; min-width: 0; }
.mail-banner-badge {
  display: inline-flex;
  align-items: center;
  background: rgba(45,122,79,0.1);
  color: #2d7a4f;
  font-size: 0.68rem;
  letter-spacing: 0.08em;
  font-weight: 700;
  padding: 6px 11px;
  border-radius: 999px;
  margin-bottom: 14px;
}
.mail-banner-title {
  font-size: 1.6rem;
  font-weight: 700;
  line-height: 1.35;
  letter-spacing: -0.02em;
  color: #20352a;
  margin-bottom: 10px;
}
.mail-banner-desc {
  font-size: 0.98rem;
  color: #577164;
  line-height: 1.85;
  margin-bottom: 14px;
}

.mail-banner-points {
  list-style: none;
  display: grid;
  gap: 8px;
}

.mail-banner-points li {
  position: relative;
  padding-left: 16px;
  font-size: 0.9rem;
  line-height: 1.65;
  color: #355141;
}

.mail-banner-points li::before {
  content: "";
  position: absolute;
  top: 0.72em;
  left: 0;
  width: 6px;
  height: 6px;
  border-radius: 999px;
  background: #2d7a4f;
}
.mail-banner-full-right {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10px;
  min-width: 280px;
  padding: 10px;
  background: rgba(255,255,255,0.7);
  border: 1px solid rgba(45,122,79,0.12);
  border-radius: 20px;
}
.mail-banner-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  width: 100%;
  background: linear-gradient(135deg, #2d7a4f 0%, #246744 55%, #1c5235 100%);
  color: #fff;
  font-weight: 700;
  font-size: 1rem;
  padding: 15px 18px;
  border-radius: 16px;
  border: 1px solid rgba(255,255,255,0.08);
  text-decoration: none;
  box-shadow: 0 12px 28px rgba(45,122,79,0.18);
  white-space: nowrap;
  transition: transform 0.15s, box-shadow 0.15s, background 0.15s;
}

.mail-banner-btn-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 30px;
  height: 30px;
  border-radius: 999px;
  background: rgba(255,255,255,0.14);
}
.mail-banner-btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 16px 32px rgba(45,122,79,0.22);
  text-decoration: none;
  color: #fff;
}
.mail-banner-note {
  font-size: 0.74rem;
  color: #6f877a;
  text-align: center;
}

@media (max-width: 800px) {
  .mail-banner-full-inner { flex-direction: column; gap: 20px; padding: 24px 20px; }
  .mail-banner-full-right { width: 100%; }
  .mail-banner-title { font-size: 1.3rem; }
  .mail-banner-desc { font-size: 0.9rem; }
}
</style>
