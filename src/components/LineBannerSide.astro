---
// サイドバー用LINEウィジェット（コンバージョン特化）
const LINE_URL = import.meta.env.PUBLIC_LINE_URL || 'https://line.me/R/ti/p/%40103khwdx';
---

<div class="line-side-widget">
  <div class="line-side-header">
    <span class="line-side-badge">📩 無料プレゼント</span>
  </div>
  <div class="line-side-body">
    <div class="line-side-report">
      <span class="line-side-report-icon">📋</span>
      <div>
        <p class="line-side-report-title">副業実録レポート</p>
        <p class="line-side-report-sub">AI副業を0から始めた<br>最初の1ヶ月の全記録</p>
      </div>
    </div>
    <ul class="line-side-list">
      <li>✅ 失敗・費用も全部公開</li>
      <li>✅ 読者限定レポート配信</li>
      <li>✅ 登録無料・解除自由</li>
    </ul>
    <a href={LINE_URL} target="_blank" rel="noopener noreferrer" class="line-side-btn">
      <svg width="18" height="18" viewBox="0 0 48 48" fill="currentColor">
        <path d="M24 4C12.95 4 4 11.84 4 21.5c0 5.8 3.2 10.96 8.18 14.3-.36 1.3-1.3 4.76-1.5 5.5-.24.9.33 .89.7.65.3-.2 4.8-3.26 6.74-4.57A22.7 22.7 0 0 0 24 39c11.05 0 20-7.84 20-17.5S35.05 4 24 4z"/>
      </svg>
      LINE登録して受け取る
    </a>
    <p class="line-side-note">登録無料・いつでも解除OK</p>
  </div>
</div>

<style>
.line-side-widget {
  background: linear-gradient(160deg, #00c300 0%, #009f00 100%);
  border-radius: 6px;
  overflow: hidden;
  color: #fff;
}

.line-side-header {
  padding: 10px 14px 0;
}

.line-side-badge {
  font-size: 0.7rem;
  font-weight: 700;
  background: rgba(255,255,255,0.2);
  padding: 2px 10px;
  border-radius: 20px;
  display: inline-block;
}

.line-side-body {
  padding: 10px 14px 14px;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.line-side-report {
  display: flex;
  gap: 10px;
  align-items: center;
  background: rgba(255,255,255,0.12);
  padding: 8px 10px;
  border-radius: 5px;
}

.line-side-report-icon { font-size: 1.6rem; flex-shrink: 0; }

.line-side-report-title {
  font-size: 0.82rem;
  font-weight: 700;
  margin-bottom: 2px;
}

.line-side-report-sub {
  font-size: 0.68rem;
  opacity: 0.85;
  line-height: 1.4;
}

.line-side-list {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 3px;
}

.line-side-list li {
  font-size: 0.72rem;
  opacity: 0.92;
}

.line-side-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 7px;
  background: #fff;
  color: #00a000;
  font-weight: 700;
  font-size: 0.85rem;
  padding: 11px;
  border-radius: 5px;
  text-decoration: none;
  box-shadow: 0 3px 10px rgba(0,0,0,0.15);
  transition: transform 0.15s, box-shadow 0.15s;
}

.line-side-btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 5px 14px rgba(0,0,0,0.2);
  text-decoration: none;
  color: #009000;
}

.line-side-note {
  text-align: center;
  font-size: 0.65rem;
  opacity: 0.75;
  margin-top: -4px;
}
</style>
