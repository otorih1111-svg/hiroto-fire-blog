---
// LINE誘導CTAブロック（記事間・ページ内挿入用）
const LINE_URL = import.meta.env.PUBLIC_LINE_URL || 'https://line.me/R/ti/p/%40103khwdx';
---

<div class="line-cta-block">
  <div class="line-cta-inner">
    <div class="line-cta-left">
      <span class="line-cta-badge">💬 完全無料</span>
      <p class="line-cta-title">「あと月1万円」を、一緒に作りませんか？</p>
      <p class="line-cta-desc">
        固定費を見直して<strong>月1万円以上浮いた話</strong>。新NISAを月1万円から始めた話。AI副業で試行錯誤した話。<br>
        シングルファーザーのひろとが実際にやった「節約→投資→副業」の流れを、失敗込みで正直に届けます。気になるテーマだけ選べます。
      </p>
      <ul class="line-cta-benefits">
        <li>✅ 節約・投資・副業、好きなテーマだけ選べる</li>
        <li>✅ 失敗・出費まで全部正直に公開</li>
        <li>✅ 登録は30秒・いつでも解除OK</li>
      </ul>
    </div>
    <div class="line-cta-right">
      <a href={LINE_URL} target="_blank" rel="noopener noreferrer" class="line-cta-btn">
        <svg width="22" height="22" viewBox="0 0 48 48" fill="currentColor">
          <path d="M24 4C12.95 4 4 11.84 4 21.5c0 5.8 3.2 10.96 8.18 14.3-.36 1.3-1.3 4.76-1.5 5.5-.24.9.33 .89.7.65.3-.2 4.8-3.26 6.74-4.57A22.7 22.7 0 0 0 24 39c11.05 0 20-7.84 20-17.5S35.05 4 24 4z"/>
        </svg>
        月1万円改善プロジェクトに参加する（無料）
      </a>
    </div>
  </div>
</div>

<style>
.line-cta-block {
  background: linear-gradient(135deg, #00c300 0%, #00a500 100%);
  border-radius: 8px;
  padding: 24px;
  margin: 28px 0;
  color: #fff;
}

.line-cta-inner {
  display: flex;
  gap: 24px;
  align-items: center;
}

.line-cta-left { flex: 1; min-width: 0; }

.line-cta-badge {
  display: inline-block;
  background: rgba(255,255,255,0.25);
  font-size: 0.72rem;
  font-weight: 700;
  padding: 3px 10px;
  border-radius: 20px;
  margin-bottom: 8px;
}

.line-cta-title {
  font-size: 1rem;
  font-weight: 700;
  line-height: 1.5;
  margin-bottom: 8px;
}

.line-cta-desc {
  font-size: 0.82rem;
  line-height: 1.7;
  opacity: 0.92;
  margin-bottom: 10px;
}

.line-cta-desc strong { color: #fff; font-weight: 700; }

.line-cta-benefits {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 3px;
}

.line-cta-benefits li {
  font-size: 0.78rem;
  opacity: 0.92;
}

.line-cta-right {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  gap: 12px;
}

.line-cta-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: #fff;
  color: #00a500;
  font-weight: 700;
  font-size: 0.88rem;
  padding: 12px 18px;
  border-radius: 6px;
  white-space: nowrap;
  box-shadow: 0 4px 14px rgba(0,0,0,0.2);
  transition: transform 0.15s, box-shadow 0.15s;
  text-decoration: none;
}

.line-cta-btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 6px 18px rgba(0,0,0,0.25);
  text-decoration: none;
  color: #009000;
}

@media (max-width: 600px) {
  .line-cta-inner { flex-direction: column; }
  .line-cta-right { width: 100%; }
  .line-cta-btn { justify-content: center; font-size: 0.85rem; padding: 13px 14px; }
}
</style>
